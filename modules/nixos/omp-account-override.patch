diff --git a/packages/coding-agent/src/slash-commands/helpers/account.ts b/packages/coding-agent/src/slash-commands/helpers/account.ts
new file mode 100644
index 000000000..2130f7472
--- /dev/null
+++ b/packages/coding-agent/src/slash-commands/helpers/account.ts
@@ -0,0 +1,37 @@
+import type { LogoutAccount } from "./logout";
+
+export interface AccountChoiceResult {
+	account?: LogoutAccount;
+	error?: string;
+}
+
+/**
+ * Resolve a `/account <query>` argument against the stored OAuth accounts:
+ * a 1-based position as rendered by the account selector, an exact label
+ * (email) match, or a unique case-insensitive substring of label/detail.
+ * Ambiguity is an error naming the candidates — never a guess.
+ */
+export function resolveAccountChoice(accounts: LogoutAccount[], query: string): AccountChoiceResult {
+	const trimmed = query.trim();
+	if (trimmed.length === 0) return { error: "Empty account query." };
+
+	if (/^\d+$/.test(trimmed)) {
+		const position = Number.parseInt(trimmed, 10);
+		const account = accounts[position - 1];
+		if (!account) return { error: `No account #${position}; valid positions are 1-${accounts.length}.` };
+		return { account };
+	}
+
+	const lowered = trimmed.toLowerCase();
+	const exact = accounts.filter(account => account.label.toLowerCase() === lowered);
+	if (exact.length === 1) return { account: exact[0] };
+
+	const matches = accounts.filter(
+		account => account.label.toLowerCase().includes(lowered) || account.detail.toLowerCase().includes(lowered),
+	);
+	if (matches.length === 1) return { account: matches[0] };
+	if (matches.length > 1) {
+		return { error: `"${trimmed}" is ambiguous: ${matches.map(match => match.label).join(", ")}.` };
+	}
+	return { error: `No stored account matches "${trimmed}".` };
+}
diff --git a/packages/coding-agent/test/account-choice.test.ts b/packages/coding-agent/test/account-choice.test.ts
new file mode 100644
index 000000000..e65f0d5d9
--- /dev/null
+++ b/packages/coding-agent/test/account-choice.test.ts
@@ -0,0 +1,48 @@
+import { describe, expect, it } from "bun:test";
+import type { LogoutAccount } from "@oh-my-pi/pi-coding-agent/slash-commands/helpers/logout";
+import { resolveAccountChoice } from "@oh-my-pi/pi-coding-agent/slash-commands/helpers/account";
+
+function account(credentialId: number, label: string, active = false): LogoutAccount {
+	return { credentialId, provider: "anthropic", label, detail: label, type: "oauth", active };
+}
+
+const ACCOUNTS: LogoutAccount[] = [
+	account(1, "alice@example.com", true),
+	account(2, "bob@example.com"),
+	account(3, "bob@corp.example.com"),
+];
+
+describe("resolveAccountChoice", () => {
+	it("resolves a 1-based position", () => {
+		expect(resolveAccountChoice(ACCOUNTS, "2").account?.credentialId).toBe(2);
+	});
+
+	it("rejects out-of-range positions", () => {
+		const result = resolveAccountChoice(ACCOUNTS, "4");
+		expect(result.account).toBeUndefined();
+		expect(result.error).toContain("1-3");
+	});
+
+	it("resolves an exact label match ahead of substring hits", () => {
+		// "bob@example.com" is also a substring-adjacent hit for account 3's
+		// domain; the exact label must win outright.
+		expect(resolveAccountChoice(ACCOUNTS, "bob@example.com").account?.credentialId).toBe(2);
+	});
+
+	it("resolves a unique case-insensitive substring", () => {
+		expect(resolveAccountChoice(ACCOUNTS, "ALICE").account?.credentialId).toBe(1);
+	});
+
+	it("reports ambiguous substrings instead of guessing", () => {
+		const result = resolveAccountChoice(ACCOUNTS, "bob");
+		expect(result.account).toBeUndefined();
+		expect(result.error).toContain("bob@example.com");
+		expect(result.error).toContain("bob@corp.example.com");
+	});
+
+	it("reports unknown queries", () => {
+		const result = resolveAccountChoice(ACCOUNTS, "nobody");
+		expect(result.account).toBeUndefined();
+		expect(result.error).toBeDefined();
+	});
+});
