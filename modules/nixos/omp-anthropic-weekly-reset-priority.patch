diff --git a/packages/ai/test/auth-storage-claude-weekly-reset-priority.test.ts b/packages/ai/test/auth-storage-claude-weekly-reset-priority.test.ts
new file mode 100644
index 000000000..e335882ec
--- /dev/null
+++ b/packages/ai/test/auth-storage-claude-weekly-reset-priority.test.ts
@@ -0,0 +1,182 @@
+import { afterEach, beforeEach, describe, expect, it, vi } from "bun:test";
+import {
+	type AuthCredential,
+	type AuthCredentialStore,
+	AuthStorage,
+	type StoredAuthCredential,
+} from "@oh-my-pi/pi-ai/auth-storage";
+import type { UsageReport } from "@oh-my-pi/pi-ai/usage";
+import * as claudeUsage from "@oh-my-pi/pi-ai/usage/claude";
+
+interface ObservableStore extends AuthCredentialStore {
+	cache: Map<string, { value: string; expiresAtSec: number }>;
+}
+
+function makeStore(rows: StoredAuthCredential[]): ObservableStore {
+	const cache = new Map<string, { value: string; expiresAtSec: number }>();
+	return {
+		cache,
+		close() {},
+		listAuthCredentials() {
+			return rows;
+		},
+		updateAuthCredential() {},
+		deleteAuthCredential() {},
+		tryDisableAuthCredentialIfMatches() {
+			return false;
+		},
+		replaceAuthCredentialsForProvider() {
+			return rows;
+		},
+		upsertAuthCredentialForProvider() {
+			return rows;
+		},
+		deleteAuthCredentialsForProvider() {},
+		getCache(key) {
+			const entry = cache.get(key);
+			if (!entry) return null;
+			if (entry.expiresAtSec * 1000 <= Date.now()) return null;
+			return entry.value;
+		},
+		setCache(key, value, expiresAtSec) {
+			cache.set(key, { value, expiresAtSec });
+		},
+		cleanExpiredCache() {},
+	};
+}
+
+function oauthRow(id: number, email: string): StoredAuthCredential {
+	const credential: AuthCredential = {
+		type: "oauth",
+		access: `oat-${id}`,
+		refresh: `refresh-${id}`,
+		expires: Date.now() + 3_600_000,
+		accountId: `account-${id}`,
+		email,
+	};
+	return { id, provider: "anthropic", credential, disabledCause: null };
+}
+
+function report(email: string, args: { weeklyUsed: number; weeklyResetsAt?: number; sessionUsed?: number }): UsageReport {
+	const sessionUsed = args.sessionUsed ?? 0.1;
+	return {
+		provider: "anthropic",
+		fetchedAt: Date.now(),
+		limits: [
+			{
+				id: "anthropic:5h",
+				label: "Claude 5 Hour",
+				scope: { provider: "anthropic", windowId: "5h", shared: true },
+				window: { id: "5h", label: "5 Hour" },
+				amount: { used: sessionUsed * 100, limit: 100, usedFraction: sessionUsed, unit: "percent" },
+				status: sessionUsed >= 1 ? "exhausted" : "ok",
+			},
+			{
+				id: "anthropic:7d",
+				label: "Claude 7 Day",
+				scope: { provider: "anthropic", windowId: "7d", shared: true },
+				window: {
+					id: "7d",
+					label: "7 Day",
+					durationMs: 7 * 24 * 60 * 60 * 1000,
+					...(args.weeklyResetsAt === undefined ? {} : { resetsAt: args.weeklyResetsAt }),
+				},
+				amount: { used: args.weeklyUsed * 100, limit: 100, usedFraction: args.weeklyUsed, unit: "percent" },
+				status: args.weeklyUsed >= 1 ? "exhausted" : "ok",
+			},
+		],
+		metadata: { email, accountId: email },
+	};
+}
+
+function mockUsage(reportsByAccess: Record<string, UsageReport>): void {
+	vi.spyOn(claudeUsage.claudeUsageProvider, "fetchUsage").mockImplementation(async params => {
+		const access = params.credential.type === "oauth" ? params.credential.accessToken : undefined;
+		if (!access) return null;
+		return reportsByAccess[access] ?? null;
+	});
+}
+
+describe("AuthStorage Claude weekly reset priority", () => {
+	let store: ObservableStore;
+	let storage: AuthStorage;
+
+	beforeEach(async () => {
+		store = makeStore([oauthRow(1, "a@example.com"), oauthRow(2, "b@example.com")]);
+		storage = new AuthStorage(store, {
+			usageProviderResolver: provider => (provider === "anthropic" ? claudeUsage.claudeUsageProvider : undefined),
+		});
+		await storage.reload();
+	});
+
+	afterEach(() => {
+		storage.close();
+		vi.restoreAllMocks();
+	});
+
+	it("always prefers the account whose weekly window resets sooner, for every session", async () => {
+		const now = Date.now();
+		mockUsage({
+			// Account 1: weekly resets tomorrow, heavily used (high drain rate).
+			"oat-1": report("a@example.com", { weeklyUsed: 0.8, weeklyResetsAt: now + 24 * 60 * 60 * 1000 }),
+			// Account 2: weekly resets in six days, barely used (low drain rate).
+			"oat-2": report("b@example.com", { weeklyUsed: 0.1, weeklyResetsAt: now + 6 * 24 * 60 * 60 * 1000 }),
+		});
+
+		// Session-sticky selection is weighted-random across priority buckets;
+		// "always" means every session must land on the sooner-reset account.
+		for (let n = 0; n < 16; n += 1) {
+			const key = await storage.getApiKey("anthropic", `session-reset-${n}`);
+			expect(key).toBe("oat-1");
+		}
+	});
+
+	it("skips an exhausted sooner-reset account instead of pinning to it", async () => {
+		const now = Date.now();
+		mockUsage({
+			// Sooner weekly reset, but the shared session window is exhausted.
+			"oat-1": report("a@example.com", {
+				weeklyUsed: 0.9,
+				weeklyResetsAt: now + 24 * 60 * 60 * 1000,
+				sessionUsed: 1.0,
+			}),
+			"oat-2": report("b@example.com", { weeklyUsed: 0.1, weeklyResetsAt: now + 6 * 24 * 60 * 60 * 1000 }),
+		});
+
+		const key = await storage.getApiKey("anthropic", "session-exhausted");
+
+		expect(key).toBe("oat-2");
+	});
+
+	it("ranks an account with an unknown weekly reset after one with a known reset", async () => {
+		const now = Date.now();
+		mockUsage({
+			// No resetsAt reported at all, otherwise idle.
+			"oat-1": report("a@example.com", { weeklyUsed: 0.0 }),
+			// Known reset far out, busier.
+			"oat-2": report("b@example.com", { weeklyUsed: 0.5, weeklyResetsAt: now + 6 * 24 * 60 * 60 * 1000 }),
+		});
+
+		for (let n = 0; n < 16; n += 1) {
+			const key = await storage.getApiKey("anthropic", `session-unknown-${n}`);
+			expect(key).toBe("oat-2");
+		}
+	});
+
+	it("keeps balancing sessions across accounts whose weekly resets tie", async () => {
+		const now = Date.now();
+		const resetsAt = now + 3 * 24 * 60 * 60 * 1000;
+		mockUsage({
+			"oat-1": report("a@example.com", { weeklyUsed: 0.3, weeklyResetsAt: resetsAt }),
+			"oat-2": report("b@example.com", { weeklyUsed: 0.3, weeklyResetsAt: resetsAt }),
+		});
+
+		const picked = new Set<string>();
+		for (let n = 0; n < 32; n += 1) {
+			const key = await storage.getApiKey("anthropic", `session-tie-${n}`);
+			if (key) picked.add(key);
+		}
+
+		expect(picked).toEqual(new Set(["oat-1", "oat-2"]));
+	});
+});
