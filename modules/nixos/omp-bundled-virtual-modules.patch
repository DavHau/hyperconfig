@@ -1250,6 +1250,41 @@ function resolveTypeBoxSpecifier(): { path: string } | undefined {
 	return TYPEBOX_SHIM_PATH ? { path: TYPEBOX_SHIM_PATH } : undefined;
 }
 
+interface LegacyPiBundledModuleResult {
+	contents: string;
+	loader: "js";
+}
+
+/**
+ * Register a runtime virtual module for every bundled registry key (except
+ * typebox, which routes through TYPEBOX_SHIM_PATH). Bun's runtime module
+ * loader never routes scheme-prefixed specifiers into plugin namespaces —
+ * `onResolve` does not fire for imports inside runtime-loaded extension
+ * modules either — so the namespace `onLoad` below is unreachable for the
+ * `omp-legacy-pi-bundled:<key>` specifiers the rewrite emits, and every
+ * compiled-binary extension import of `@oh-my-pi/*` failed with
+ * `Cannot find module 'omp-legacy-pi-bundled:...'`. `build.module()` is the
+ * documented runtime virtual-module mechanism and DOES resolve there.
+ *
+ * Exported as a test seam: `registerModule` receives each virtual specifier
+ * and its lazy source callback; `synthesize` defaults to the live registry
+ * synthesizer.
+ */
+export function __registerLegacyPiBundledVirtualModules(
+	registerModule: (specifier: string, callback: () => Promise<LegacyPiBundledModuleResult>) => void,
+	synthesize: (registryKey: string) => Promise<string> = synthesizeBundledModuleSource,
+): void {
+	for (const key of BUNDLED_PI_REGISTRY_KEYS) {
+		if (key === TYPEBOX_BUNDLED_REGISTRY_KEY) {
+			continue;
+		}
+		registerModule(bundledRegistryVirtualSpecifier(key), async () => ({
+			contents: await synthesize(key),
+			loader: "js",
+		}));
+	}
+}
+
 export function installLegacyPiSpecifierShim(): void {
 	if (isLegacyPiSpecifierShimInstalled) {
 		return;
@@ -1264,9 +1299,14 @@ export function installLegacyPiSpecifierShim(): void {
 			// Compiled-binary mode: serve `omp-legacy-pi-bundled:<key>` imports
 			// from the JS-heap registry. The rewrite path emits these specifiers
 			// in place of unreachable `file:///$bunfs/...` URLs (issue #3423).
+			// Runtime imports resolve through the `build.module` registrations;
+			// the namespace `onLoad` is kept for bundler-path consumers.
 			build.onLoad({ filter: /.*/, namespace: BUNDLED_VIRTUAL_NAMESPACE }, async args => {
 				return { contents: await synthesizeBundledModuleSource(args.path), loader: "js" };
 			});
+			if (IS_COMPILED_BINARY) {
+				__registerLegacyPiBundledVirtualModules((specifier, callback) => build.module(specifier, callback));
+			}
 		},
 	});
 }
