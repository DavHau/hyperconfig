 });
+
+// Regression for the runtime-resolution gap behind issue #3423's fix: the
+// virtual `omp-legacy-pi-bundled:<key>` specifiers were served by a
+// namespace-scoped `onLoad`, but Bun's RUNTIME module loader (used for
+// dynamically imported extensions) never routes scheme-prefixed bare
+// specifiers into plugin namespaces — `onResolve` does not fire for imports
+// inside runtime-loaded modules either. Every compiled-binary extension
+// import of `@oh-my-pi/*` therefore failed with `Cannot find module
+// 'omp-legacy-pi-bundled:...'`. Runtime virtual modules registered via
+// `build.module(specifier, cb)` are the documented mechanism that DOES
+// resolve at runtime, so the shim must register one per bundled key.
+describe("legacy-pi bundled virtual module registration", () => {
+	it("registers a runtime virtual module for every bundled key except typebox", async () => {
+		const { __registerLegacyPiBundledVirtualModules } = await import(
+			"@oh-my-pi/pi-coding-agent/extensibility/plugins/legacy-pi-compat"
+		);
+		const { BUNDLED_PI_REGISTRY_KEYS } = await import(
+			"@oh-my-pi/pi-coding-agent/extensibility/plugins/legacy-pi-bundled-keys"
+		);
+		const registered = new Map<string, () => Promise<{ contents: string; loader: string }>>();
+		__registerLegacyPiBundledVirtualModules((specifier, callback) => {
+			registered.set(specifier, callback);
+		});
+		expect(registered.has("omp-legacy-pi-bundled:@oh-my-pi/pi-coding-agent/async/job-manager")).toBe(true);
+		expect(registered.has("omp-legacy-pi-bundled:@oh-my-pi/pi-tui")).toBe(true);
+		expect(registered.has("omp-legacy-pi-bundled:typebox")).toBe(false);
+		// one registration per non-typebox key, all scheme-prefixed
+		expect(registered.size).toBe(BUNDLED_PI_REGISTRY_KEYS.size - (BUNDLED_PI_REGISTRY_KEYS.has("typebox") ? 1 : 0));
+		for (const specifier of registered.keys()) {
+			expect(specifier.startsWith("omp-legacy-pi-bundled:")).toBe(true);
+		}
+	});
+
+	it("serves synthesized registry source through the registered callback", async () => {
+		const { __registerLegacyPiBundledVirtualModules } = await import(
+			"@oh-my-pi/pi-coding-agent/extensibility/plugins/legacy-pi-compat"
+		);
+		const registered = new Map<string, () => Promise<{ contents: string; loader: string }>>();
+		__registerLegacyPiBundledVirtualModules(
+			(specifier, callback) => {
+				registered.set(specifier, callback);
+			},
+			async key => `export const KEY = ${JSON.stringify(key)};`,
+		);
+		const callback = registered.get("omp-legacy-pi-bundled:@oh-my-pi/pi-tui")!;
+		const result = await callback();
+		expect(result.loader).toBe("js");
+		expect(result.contents).toBe('export const KEY = "@oh-my-pi/pi-tui";');
+	});
+});
