diff --git a/packages/coding-agent/src/task/vcs.ts b/packages/coding-agent/src/task/vcs.ts
new file mode 100644
index 000000000..d1949ebfe
--- /dev/null
+++ b/packages/coding-agent/src/task/vcs.ts
@@ -0,0 +1,143 @@
+/**
+ * VCS seam for isolated task execution.
+ *
+ * Task isolation has two VCS-shaped phases wrapped around a VCS-agnostic
+ * filesystem snapshot (the PAL backend):
+ *
+ *   1. capture — record a baseline before the spawn, then diff/commit the
+ *      isolated worktree against it after the agent finishes,
+ *   2. merge-back — land those captured changes in the (live, possibly
+ *      moved-on) parent workspace, surfacing overlaps as conflicts.
+ *
+ * Both phases go through this `VcsHandle` interface instead of calling git
+ * helpers directly, so alternative backends (e.g. jj workspaces resolving
+ * their shared backing git store) can plug in without touching the isolation
+ * lifecycle in `isolation-runner.ts` or its callers.
+ *
+ * `GitCheckoutHandle` is the only implementation today and delegates to the
+ * existing machinery in `worktree.ts` / `utils/git.ts` unchanged.
+ */
+import * as git from "../utils/git";
+import {
+	applyNestedPatches,
+	captureBaseline,
+	captureDeltaPatch,
+	cleanupTaskBranches,
+	commitToBranch,
+	type CommitToBranchResult,
+	type DeltaPatchResult,
+	getRepoRoot,
+	type MergeBranchResult,
+	mergeTaskBranches,
+	type NestedRepoPatch,
+	type WorktreeBaseline,
+} from "./worktree";
+
+/** A task ref to merge back into the parent workspace (branch mode). */
+export interface TaskRefMergeSpec {
+	branchName: string;
+	taskId: string;
+	description?: string;
+	baseSha?: string;
+}
+
+/**
+ * VCS operations required by isolated task execution. One handle is resolved
+ * per isolation context (i.e. per task-tool call / eval `agent()` spawn batch)
+ * and shared by every spawn in that call.
+ */
+export interface VcsHandle {
+	/** Backend discriminator; drives capability checks and user messaging. */
+	readonly kind: "git";
+	/** Workspace root — the directory the PAL snapshots and merges land in. */
+	readonly root: string;
+
+	/** Record pre-spawn state to diff each isolated run against. */
+	captureBaseline(): Promise<WorktreeBaseline>;
+	/** Diff the isolated worktree against the baseline (patch mode + recovery artifacts). */
+	captureDelta(isolationDir: string, baseline: WorktreeBaseline): Promise<DeltaPatchResult>;
+	/**
+	 * Commit task-only changes from the isolated worktree onto a parked task
+	 * ref (branch mode). Returns `null` when there is nothing to commit.
+	 */
+	commitToTaskRef(
+		isolationDir: string,
+		baseline: WorktreeBaseline,
+		taskId: string,
+		description: string | undefined,
+		commitMessage?: (diff: string) => Promise<string | null>,
+	): Promise<CommitToBranchResult | null>;
+	/** Land parked task refs in the parent workspace; overlaps surface as conflicts. */
+	mergeTaskRefs(refs: TaskRefMergeSpec[]): Promise<MergeBranchResult>;
+	/** Delete parked task refs after a successful merge. */
+	cleanupTaskRefs(branchNames: string[]): Promise<void>;
+
+	/** Check whether a delta patch applies cleanly to the parent workspace (read-only). */
+	canApplyPatch(patchText: string, options?: { reverse?: boolean }): Promise<boolean>;
+	/** Apply a delta patch to the parent workspace (patch mode merge). */
+	applyPatch(patchText: string): Promise<void>;
+	/** Apply nested-repo patches to their working directories; returns warnings. */
+	applyNestedPatches(
+		patches: NestedRepoPatch[],
+		commitMessage?: (diff: string) => Promise<string | null>,
+	): Promise<string[]>;
+}
+
+/** Plain git checkout — delegates to the existing worktree/git machinery. */
+export class GitCheckoutHandle implements VcsHandle {
+	readonly kind = "git" as const;
+	constructor(readonly root: string) {}
+
+	captureBaseline(): Promise<WorktreeBaseline> {
+		return captureBaseline(this.root);
+	}
+
+	captureDelta(isolationDir: string, baseline: WorktreeBaseline): Promise<DeltaPatchResult> {
+		return captureDeltaPatch(isolationDir, baseline);
+	}
+
+	commitToTaskRef(
+		isolationDir: string,
+		baseline: WorktreeBaseline,
+		taskId: string,
+		description: string | undefined,
+		commitMessage?: (diff: string) => Promise<string | null>,
+	): Promise<CommitToBranchResult | null> {
+		return commitToBranch(isolationDir, baseline, taskId, description, commitMessage);
+	}
+
+	mergeTaskRefs(refs: TaskRefMergeSpec[]): Promise<MergeBranchResult> {
+		return mergeTaskBranches(this.root, refs);
+	}
+
+	cleanupTaskRefs(branchNames: string[]): Promise<void> {
+		return cleanupTaskBranches(this.root, branchNames);
+	}
+
+	canApplyPatch(patchText: string, options?: { reverse?: boolean }): Promise<boolean> {
+		return git.patch.canApplyText(this.root, patchText, options);
+	}
+
+	applyPatch(patchText: string): Promise<void> {
+		return git.patch.applyText(this.root, patchText);
+	}
+
+	applyNestedPatches(
+		patches: NestedRepoPatch[],
+		commitMessage?: (diff: string) => Promise<string | null>,
+	): Promise<string[]> {
+		return applyNestedPatches(this.root, patches, commitMessage);
+	}
+}
+
+/**
+ * Resolve the VCS handle for isolated task execution at `cwd`.
+ *
+ * Today: nearest git checkout wins; a pure jj workspace (`.jj/` without a
+ * colocated `.git/`) is rejected with colocation guidance — the same gate
+ * `getRepoRoot` has always enforced. A future jj handle slots in here.
+ */
+export async function resolveVcsHandle(cwd: string): Promise<VcsHandle> {
+	const root = await getRepoRoot(cwd);
+	return new GitCheckoutHandle(root);
+}
