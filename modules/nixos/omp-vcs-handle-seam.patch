+/**
+ * Behavior tests for the VCS seam (`resolveVcsHandle`): isolated-task capture
+ * and merge-back go through a `VcsHandle` so backends other than a plain git
+ * checkout (e.g. jj workspaces) can plug in without touching the isolation
+ * lifecycle. These tests pin the handle-selection contract:
+ *   - a git checkout resolves to the git handle rooted at the checkout root,
+ *   - a pure jj workspace (no colocated `.git/`) is rejected with the
+ *     colocation guidance (current gate behavior, unchanged),
+ *   - a directory outside any repo is rejected.
+ */
+import { afterEach, describe, expect, it } from "bun:test";
+import * as fs from "node:fs/promises";
+import * as os from "node:os";
+import * as path from "node:path";
+import { resolveVcsHandle } from "@oh-my-pi/pi-coding-agent/task/vcs";
+import { removeWithRetries } from "@oh-my-pi/pi-utils";
+
+async function run(cwd: string, cmd: string[]): Promise<string> {
+	const proc = Bun.spawn(cmd, {
+		cwd,
+		stdout: "pipe",
+		stderr: "pipe",
+		windowsHide: true,
+		env: { ...process.env, JJ_USER: "Test User", JJ_EMAIL: "test@example.com" },
+	});
+	const [stdout, stderr, exitCode] = await Promise.all([
+		new Response(proc.stdout).text(),
+		new Response(proc.stderr).text(),
+		proc.exited,
+	]);
+	if ((exitCode ?? 0) !== 0) {
+		throw new Error(stderr.trim() || stdout.trim() || `${cmd.join(" ")} failed with exit code ${exitCode ?? 0}`);
+	}
+	return stdout.trim();
+}
+
+const jjAvailable = await Bun.spawn(["jj", "--version"], { stdout: "ignore", stderr: "ignore" })
+	.exited.then(code => code === 0)
+	.catch(() => false);
+
+describe("resolveVcsHandle", () => {
+	const tempDirs: string[] = [];
+
+	afterEach(async () => {
+		await Promise.all(tempDirs.splice(0).map(dir => removeWithRetries(dir)));
+	});
+
+	async function tempDir(prefix: string): Promise<string> {
+		const dir = await fs.mkdtemp(path.join(os.tmpdir(), prefix));
+		tempDirs.push(dir);
+		return dir;
+	}
+
+	async function createGitRepo(): Promise<string> {
+		const repo = await tempDir("omp-vcs-git-");
+		await run(repo, ["git", "init", "-qb", "main"]);
+		await run(repo, ["git", "config", "user.email", "test@example.com"]);
+		await run(repo, ["git", "config", "user.name", "Test User"]);
+		await fs.writeFile(path.join(repo, "base.txt"), "base\n");
+		await run(repo, ["git", "add", "base.txt"]);
+		await run(repo, ["git", "commit", "-qm", "base"]);
+		return repo;
+	}
+
+	it("resolves a git checkout to a git handle rooted at the checkout", async () => {
+		const repo = await createGitRepo();
+		const nested = path.join(repo, "src", "deep");
+		await fs.mkdir(nested, { recursive: true });
+
+		const handle = await resolveVcsHandle(nested);
+
+		expect(handle.kind).toBe("git");
+		expect(await fs.realpath(handle.root)).toBe(await fs.realpath(repo));
+	});
+
+	it.skipIf(!jjAvailable)("rejects a pure jj secondary workspace with colocation guidance", async () => {
+		// `jj workspace add` secondary workspaces carry `.jj/repo` as a pointer
+		// file and never get a `.git/` — the realistic pure-jj shape (jj >= 0.34
+		// colocates `jj git init` by default).
+		const main = await tempDir("omp-vcs-jjmain-");
+		await run(main, ["jj", "git", "init"]);
+		const ws = path.join(path.dirname(main), `${path.basename(main)}-ws2`);
+		await run(main, ["jj", "workspace", "add", ws]);
+		tempDirs.push(ws);
+
+		await expect(resolveVcsHandle(ws)).rejects.toThrow(/pure Jujutsu.*--colocate/s);
+	});
+
+	it("rejects a directory outside any repository", async () => {
+		const dir = await tempDir("omp-vcs-norepo-");
+
+		await expect(resolveVcsHandle(dir)).rejects.toThrow(/Git repository not found/);
+	});
+});
