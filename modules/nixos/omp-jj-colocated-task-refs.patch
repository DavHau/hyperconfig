diff --git a/packages/coding-agent/test/task/worktree.test.ts b/packages/coding-agent/test/task/worktree.test.ts
index 3ac79ef9d..118374412 100644
--- a/packages/coding-agent/test/task/worktree.test.ts
+++ b/packages/coding-agent/test/task/worktree.test.ts
@@ -1006,4 +1006,82 @@ describe("commitToBranch preserves agent commits", () => {
 			expect(branchDiff).toContain("+agent-edit");
 		});
 	});
+	// Regression for the colocated-jj disaster: task refs under refs/heads/*
+	// are imported (pinned) by any concurrent `jj` invocation in a colocated
+	// checkout; the later branch deletion then makes jj abandon the pinned
+	// commits and rebase the repo's whole commit stack onto a stale bookmark
+	// (silently orphaning every commit in between). Keeping the refs outside
+	// refs/heads/* makes them invisible to jj while every git command still
+	// resolves the short name via the refs/<name> fallback.
+	describe("task refs stay outside refs/heads (colocated jj safety)", () => {
+		async function expectHiddenTaskRef(taskId: string): Promise<void> {
+			const refName = `omp/task/${taskId}`;
+			// Not a branch: invisible to `git branch` consumers and jj import.
+			await expect(gitr(parent, ["show-ref", "--verify", `refs/heads/${refName}`])).rejects.toThrow();
+			// Still resolvable via git's refs/<name> fallback.
+			const sha = await gitr(parent, ["rev-parse", "--verify", `${refName}^{commit}`]);
+			expect(sha).toMatch(/^[0-9a-f]{40}$/);
+		}
+
+		async function expectMergeAndCleanup(taskId: string, result: { branchName?: string; baseSha?: string }): Promise<void> {
+			const merge = await mergeTaskBranches(parent, [
+				{ branchName: result.branchName!, taskId, baseSha: result.baseSha! },
+			]);
+			expect(merge.failed).toEqual([]);
+			expect(merge.merged).toEqual([result.branchName!]);
+			await cleanupTaskBranches(parent, [result.branchName!]);
+			await expect(gitr(parent, ["rev-parse", "--verify", `${result.branchName!}^{commit}`])).rejects.toThrow();
+		}
+
+		it("keeps the ref hidden when the agent committed inside isolation", async () => {
+			const baseline = await captureBaseline(parent);
+			await fs.writeFile(path.join(isolation, "agent.txt"), "agent work\n");
+			await gitr(isolation, ["add", "agent.txt"]);
+			await gitr(isolation, ["commit", "-q", "-m", "feat: agent work"]);
+			// Leftover on top of the commit exercises the temp-worktree append path.
+			await fs.writeFile(path.join(isolation, "leftover.txt"), "leftover\n");
+
+			const taskId = "jj-safe-committed";
+			const result = await commitToBranch(isolation, baseline, taskId, undefined, async () => "chore: leftover");
+			expect(result?.branchName).toBe(`omp/task/${taskId}`);
+
+			await expectHiddenTaskRef(taskId);
+			await expectMergeAndCleanup(taskId, result!);
+			expect(await fs.readFile(path.join(parent, "agent.txt"), "utf8")).toBe("agent work\n");
+			expect(await fs.readFile(path.join(parent, "leftover.txt"), "utf8")).toBe("leftover\n");
+		});
+
+		it("keeps the ref hidden when the agent left only uncommitted changes", async () => {
+			const baseline = await captureBaseline(parent);
+			await fs.writeFile(path.join(isolation, "agent.txt"), "uncommitted agent work\n");
+
+			const taskId = "jj-safe-uncommitted";
+			const result = await commitToBranch(isolation, baseline, taskId, undefined, async () => "feat: agent work");
+			expect(result?.branchName).toBe(`omp/task/${taskId}`);
+
+			await expectHiddenTaskRef(taskId);
+			await expectMergeAndCleanup(taskId, result!);
+			expect(await fs.readFile(path.join(parent, "agent.txt"), "utf8")).toBe("uncommitted agent work\n");
+		});
+
+		it("keeps the ref hidden on the dirty-baseline replay path", async () => {
+			// Baseline WIP in the parent forces replayFilteredAgentCommits
+			// (same seeding as "filters baseline WIP when the agent commits").
+			await fs.writeFile(path.join(parent, "staged.txt"), "baseline staged wip\n");
+			await gitr(parent, ["add", "staged.txt"]);
+			await fs.writeFile(path.join(isolation, "staged.txt"), "baseline staged wip\n");
+			await gitr(isolation, ["add", "staged.txt"]);
+			const baseline = await captureBaseline(parent);
+
+			await fs.writeFile(path.join(isolation, "agent.txt"), "agent work\n");
+			await gitr(isolation, ["add", "agent.txt"]);
+			await gitr(isolation, ["commit", "-q", "-m", "feat: agent work"]);
+
+			const taskId = "jj-safe-replay";
+			const result = await commitToBranch(isolation, baseline, taskId, undefined);
+			expect(result?.branchName).toBe(`omp/task/${taskId}`);
+
+			await expectHiddenTaskRef(taskId);
+		});
+	});
 });
