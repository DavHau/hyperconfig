+/**
+ * Full ref name for a task branch. Task refs live OUTSIDE `refs/heads/` on
+ * purpose: in a colocated jj checkout, jj imports `refs/heads/*` on every
+ * invocation — a transient task branch gets pinned by any concurrent `jj`
+ * run (shell prompt, watcher, the user), and the branch deletion after a
+ * successful merge then makes jj abandon the pinned commits and rebase the
+ * parent's entire commit stack onto a stale bookmark, silently orphaning
+ * every commit in between. `refs/omp/task/*` is invisible to jj while every
+ * git command still resolves the short `omp/task/<id>` name through git's
+ * `refs/<name>` lookup fallback.
+ *
+ * Accepts already-qualified names so legacy callers that pass a real branch
+ * are left untouched.
+ */
+export function taskBranchRef(branchName: string): string {
+	return branchName.startsWith("refs/") ? branchName : `refs/${branchName}`;
+}
+
+/**
+ * Point the task ref at the temp worktree's HEAD after a commit landed
+ * there. Detached temp worktrees don't advance any ref on commit, so the
+ * ref move is explicit.
+ */
+async function advanceTaskRef(repoRoot: string, tmpDir: string, branchName: string, taskId: string): Promise<void> {
+	const tip = await git.head.sha(tmpDir);
+	if (!tip) throw new Error(`task ${taskId}: temp worktree HEAD unresolvable after branch commit`);
+	await git.ref.update(repoRoot, taskBranchRef(branchName), tip);
+}
 
