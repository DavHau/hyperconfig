diff --git a/packages/coding-agent/test/status-line-auth-warmup.test.ts b/packages/coding-agent/test/status-line-auth-warmup.test.ts
new file mode 100644
index 000000000..e4f9db9f4
--- /dev/null
+++ b/packages/coding-agent/test/status-line-auth-warmup.test.ts
@@ -0,0 +1,126 @@
+import { beforeAll, describe, expect, it } from "bun:test";
+import { stripVTControlCharacters } from "node:util";
+import { resetSettingsForTest, Settings } from "@oh-my-pi/pi-coding-agent/config/settings";
+import { StatusLineComponent } from "@oh-my-pi/pi-coding-agent/modes/components/status-line";
+import { initTheme } from "@oh-my-pi/pi-coding-agent/modes/theme/theme";
+
+beforeAll(async () => {
+	resetSettingsForTest();
+	await Settings.init({ inMemory: true });
+	await initTheme();
+});
+
+interface WarmupHarness {
+	component: StatusLineComponent;
+	getApiKeyCalls: Array<{ provider: string; sessionId?: string; options?: { modelId?: string } }>;
+	renderRequests: () => number;
+}
+
+function makeHarness(args: { provider?: string; oauthStored?: boolean; email?: string }): WarmupHarness {
+	const provider = args.provider ?? "anthropic";
+	const oauthStored = args.oauthStored ?? true;
+	const email = args.email ?? "ranked@example.com";
+	let attributed = false;
+	const getApiKeyCalls: WarmupHarness["getApiKeyCalls"] = [];
+	const component = new StatusLineComponent({
+		sessionId: "session-warmup",
+		state: { messages: [], model: { contextWindow: 1000, provider, id: "test-model" } },
+		model: { contextWindow: 1000, provider, id: "test-model" },
+		sessionManager: {
+			getUsageStatistics: () => ({
+				input: 0,
+				output: 0,
+				cacheRead: 0,
+				cacheWrite: 0,
+				totalTokens: 0,
+				orchestrationInput: 0,
+				orchestrationOutput: 0,
+				orchestrationCacheRead: 0,
+				premiumRequests: 0,
+				cost: 0,
+			}),
+		},
+		fetchUsageReports: async () => [],
+		modelRegistry: {
+			isUsingOAuth: () => oauthStored,
+			authStorage: {
+				getOAuthAccountIdentity: (
+					requestedProvider: string,
+					_sessionId?: string,
+					options?: { sessionStickyOnly?: boolean },
+				) => {
+					if (!oauthStored || requestedProvider !== provider) return undefined;
+					if (options?.sessionStickyOnly === true && !attributed) return undefined;
+					return { accountId: "acc-ranked", email };
+				},
+				getApiKey: async (requestedProvider: string, sessionId?: string, options?: { modelId?: string }) => {
+					getApiKeyCalls.push({ provider: requestedProvider, sessionId, options });
+					// Real selection ranks usage before recording stickiness; keep
+					// the flip asynchronous so the pre-warm-up render is observable.
+					await Promise.resolve();
+					attributed = true;
+					return "oat-ranked";
+				},
+			},
+		},
+		getAsyncJobSnapshot: () => ({ running: [] }),
+		getContextUsage: () => undefined,
+	} as unknown as ConstructorParameters<typeof StatusLineComponent>[0]);
+	component.updateSettings({
+		preset: "custom",
+		leftSegments: [],
+		rightSegments: ["cost"],
+		sessionAccent: false,
+	});
+	let renders = 0;
+	component.watchBranch(() => {
+		renders += 1;
+	});
+	return { component, getApiKeyCalls, renderRequests: () => renders };
+}
+
+// The warm-up chain is promise-only (mock getApiKey resolves immediately);
+// draining microtasks is deterministic — no wall-clock timers needed.
+async function flushAsync(): Promise<void> {
+	for (let i = 0; i < 8; i += 1) {
+		await Promise.resolve();
+	}
+}
+
+describe("status-line OAuth attribution warm-up", () => {
+	it("resolves the session credential once on first render", async () => {
+		const h = makeHarness({});
+		h.component.getTopBorder(200);
+		h.component.getTopBorder(200);
+		await flushAsync();
+		h.component.getTopBorder(200);
+
+		expect(h.getApiKeyCalls).toHaveLength(1);
+		expect(h.getApiKeyCalls[0]).toEqual({
+			provider: "anthropic",
+			sessionId: "session-warmup",
+			options: { modelId: "test-model" },
+		});
+	});
+
+	it("shows the attributed account email right after the warm-up resolves", async () => {
+		const h = makeHarness({});
+		const before = stripVTControlCharacters(h.component.getTopBorder(200).content);
+		expect(before).not.toContain("ranked@example.com");
+
+		await flushAsync();
+		const after = stripVTControlCharacters(h.component.getTopBorder(200).content);
+		expect(after).toContain("ranked@example.com");
+		// Warm-up completion must request a repaint so the email appears
+		// without waiting for the next unrelated UI event.
+		expect(h.renderRequests()).toBeGreaterThan(0);
+	});
+
+	it("skips the warm-up when no OAuth credential is in play", async () => {
+		const h = makeHarness({ oauthStored: false });
+		h.component.getTopBorder(200);
+		await flushAsync();
+
+		expect(h.getApiKeyCalls).toHaveLength(0);
+	});
+});
diff --git a/packages/coding-agent/test/status-line-cost-account.test.ts b/packages/coding-agent/test/status-line-cost-account.test.ts
new file mode 100644
index 000000000..9e21c56c7
--- /dev/null
+++ b/packages/coding-agent/test/status-line-cost-account.test.ts
@@ -0,0 +1,113 @@
+import { beforeAll, describe, expect, it } from "bun:test";
+import { stripVTControlCharacters } from "node:util";
+import { renderSegment } from "@oh-my-pi/pi-coding-agent/modes/components/status-line/segments";
+import type { SegmentContext } from "@oh-my-pi/pi-coding-agent/modes/components/status-line/types";
+import { initTheme } from "@oh-my-pi/pi-coding-agent/modes/theme/theme";
+
+beforeAll(async () => {
+	await initTheme();
+});
+
+function ctxWith(args: {
+	cost?: number;
+	provider?: string;
+	oauth?: boolean;
+	identity?: { email?: string; accountId?: string };
+	/** Session-sticky attribution exists (default true). */
+	attributed?: boolean;
+}): SegmentContext {
+	return {
+		usageStats: {
+			input: 0,
+			output: 0,
+			cacheRead: 0,
+			cacheWrite: 0,
+			totalTokens: 0,
+			orchestrationInput: 0,
+			orchestrationOutput: 0,
+			orchestrationCacheRead: 0,
+			premiumRequests: 0,
+			cost: args.cost ?? 0,
+			tokensPerSecond: null,
+		},
+		session: {
+			sessionId: "session-1",
+			state: { model: args.provider ? { provider: args.provider, id: "test-model" } : undefined },
+			modelRegistry: {
+				isUsingOAuth: () => args.oauth ?? false,
+				authStorage: {
+					getOAuthAccountIdentity: (
+						provider: string,
+						_sessionId?: string,
+						options?: { sessionStickyOnly?: boolean },
+					) => {
+						if (provider !== args.provider) return undefined;
+						if (options?.sessionStickyOnly === true && args.attributed === false) return undefined;
+						return args.identity;
+					},
+				},
+			},
+		},
+	} as unknown as SegmentContext;
+}
+
+function plain(text: string): string {
+	return stripVTControlCharacters(text);
+}
+
+describe("cost status-line segment account email", () => {
+	it("appends the active Anthropic account email next to the cost", () => {
+		const result = renderSegment(
+			"cost",
+			ctxWith({ cost: 1.23, provider: "anthropic", oauth: true, identity: { email: "a@example.com" } }),
+		);
+		expect(result.visible).toBe(true);
+		const text = plain(result.content);
+		expect(text).toContain("$1.23");
+		expect(text).toContain("a@example.com");
+		expect(text.indexOf("a@example.com")).toBeGreaterThan(text.indexOf("$1.23"));
+	});
+
+	it("shows the email even at zero cost while on subscription", () => {
+		const result = renderSegment(
+			"cost",
+			ctxWith({ provider: "anthropic", oauth: true, identity: { email: "a@example.com" } }),
+		);
+		expect(result.visible).toBe(true);
+		const text = plain(result.content);
+		expect(text).toContain("(sub)");
+		expect(text).toContain("a@example.com");
+	});
+
+	it("hides the email for non-Anthropic providers", () => {
+		const result = renderSegment(
+			"cost",
+			ctxWith({ cost: 1.23, provider: "openai-codex", oauth: true, identity: { email: "a@example.com" } }),
+		);
+		expect(result.visible).toBe(true);
+		expect(plain(result.content)).not.toContain("a@example.com");
+	});
+
+	it("omits the email when no OAuth identity is attributed", () => {
+		const result = renderSegment("cost", ctxWith({ cost: 1.23, provider: "anthropic", oauth: true }));
+		expect(result.visible).toBe(true);
+		expect(plain(result.content)).not.toContain("@");
+	});
+
+	it("hides the first-account fallback email before the session is attributed", () => {
+		const result = renderSegment(
+			"cost",
+			ctxWith({
+				cost: 1.23,
+				provider: "anthropic",
+				oauth: true,
+				identity: { email: "a@example.com" },
+				attributed: false,
+			}),
+		);
+		expect(result.visible).toBe(true);
+		const text = plain(result.content);
+		expect(text).toContain("$1.23");
+		expect(text).not.toContain("a@example.com");
+	});
+});
