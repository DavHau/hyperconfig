diff --git a/packages/coding-agent/src/session/yield-queue.ts b/packages/coding-agent/src/session/yield-queue.ts
index 9afe4fb14..3afd31c54 100644
--- a/packages/coding-agent/src/session/yield-queue.ts
+++ b/packages/coding-agent/src/session/yield-queue.ts
@@ -135,6 +135,32 @@ export class YieldQueue {
 		this.#idleFlushPending = false;
 	}
 
+	/**
+	 * Recover entries stranded at a turn boundary. Three ways entries survive
+	 * with no flush scheduled: enqueued mid-stream after the loop's final aside
+	 * poll (turn unwind), skipped by an abort (the loop bypasses its exit
+	 * drains), or a scheduled idle flush that never ran (an aborted post-prompt
+	 * task would otherwise latch #idleFlushPending forever). Call when the
+	 * session settles to idle; no-op while streaming or without eligible
+	 * entries. Racing an already-pending flush is safe — the second flush
+	 * drains nothing and injects nothing.
+	 */
+	notifyIdle(): void {
+		if (this.#options.isStreaming()) return;
+		if (!this.#hasIdleFlushWork()) return;
+		this.#idleFlushPending = false;
+		this.#scheduleIdleFlush();
+	}
+
+	#hasIdleFlushWork(): boolean {
+		for (const [kind, entries] of this.#entries) {
+			if (entries.length === 0) continue;
+			if (this.#dispatchers.get(kind)?.skipIdleFlush) continue;
+			return true;
+		}
+		return false;
+	}
+
 	#scheduleIdleFlush(): void {
 		if (this.#idleFlushPending) return;
