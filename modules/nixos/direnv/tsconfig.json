{
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"lib": ["ES2024"],
		"moduleResolution": "Bundler",
		"moduleDetection": "force",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"esModuleInterop": true,
		"types": ["bun", "assets"],
		"typeRoots": ["../../../../oh-my-pi/types", "./node_modules/@types"]
	},
	"include": ["*.ts"]
}
