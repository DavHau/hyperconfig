+func statLookup(m map[int]procStat) func(int) (procStat, bool) {
+	return func(p int) (procStat, bool) { s, ok := m[p]; return s, ok }
+}
+
+func TestAncestryWalk(t *testing.T) {
+	lookup := statLookup(map[int]procStat{
+		205: {name: "ssh", ppid: 201, start: 55},
+		201: {name: "omp", ppid: 100, start: 51},
+		100: {name: "bwrap", ppid: 7, start: 10},
+		7:   {name: "zsh", ppid: 1, start: 1},
+	})
+	got := ancestryOf(205, lookup)
+	want := []Proc{
+		{PID: 205, Start: 55, Name: "ssh"},
+		{PID: 201, Start: 51, Name: "omp"},
+		{PID: 100, Start: 10, Name: "bwrap"},
+		{PID: 7, Start: 1, Name: "zsh"},
+	}
+	if len(got) != len(want) {
+		t.Fatalf("ancestry length = %d, want %d (%v)", len(got), len(want), got)
+	}
+	for i := range want {
+		if got[i] != want[i] {
+			t.Errorf("ancestry[%d] = %+v, want %+v", i, got[i], want[i])
+		}
+	}
+}
+
+func TestAncestryWalkStopsAtUnreadableParent(t *testing.T) {
+	lookup := statLookup(map[int]procStat{
+		205: {name: "ssh", ppid: 201, start: 55},
+	})
+	got := ancestryOf(205, lookup)
+	if len(got) != 1 || got[0].PID != 205 {
+		t.Errorf("walk must keep the readable prefix, got %v", got)
+	}
+}
+
+func TestAncestryWalkRealProc(t *testing.T) {
+	// Integration against the real /proc: our own ancestry starts with this
+	// test process and has at least one parent.
+	got := ancestryOf(os.Getpid(), readStat)
+	if len(got) < 2 {
+		t.Fatalf("expected self + at least one ancestor, got %v", got)
+	}
+	if got[0].PID != os.Getpid() {
+		t.Errorf("ancestry[0].PID = %d, want %d", got[0].PID, os.Getpid())
+	}
+	if got[0].Name == "" || got[0].Start == 0 {
+		t.Errorf("ancestry[0] lacks name/start: %+v", got[0])
+	}
+}
+
+func TestChainAndChoices(t *testing.T) {
+	id := chainOf(
+		Proc{PID: 205, Start: 55, Name: "ssh"},
+		Proc{PID: 201, Start: 51, Name: "omp"},
+		Proc{PID: 100, Start: 10, Name: "bwrap"},
+		Proc{PID: 7, Start: 1, Name: "zsh"},
+		Proc{PID: 5, Start: 1, Name: "systemd"},
+	)
+	if got, want := id.Chain(), "ssh (205) ← omp ← bwrap ← zsh"; got != want {
+		t.Errorf("Chain() = %q, want %q", got, want)
+	}
+	if got := id.Choices(); len(got) != 4 {
+		t.Errorf("Choices() must cap at the displayed chain, got %d entries", len(got))
+	}
+	// Find still sees the full ancestry, beyond the displayed prefix.
+	if _, ok := id.Find(5); !ok {
+		t.Error("Find must cover the full ancestry")
+	}
+	if _, ok := id.Find(9999); ok {
+		t.Error("Find must miss unknown pids")
+	}
+}
