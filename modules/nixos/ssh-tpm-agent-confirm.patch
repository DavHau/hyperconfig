diff --git a/internal/peerid/grant.go b/internal/peerid/grant.go
new file mode 100644
index 0000000..f15524d
--- /dev/null
+++ b/internal/peerid/grant.go
@@ -0,0 +1,79 @@
+package peerid
+
+import (
+	"sync"
+	"time"
+)
+
+type grantKey struct {
+	uid         uint32
+	sid         int
+	leaderStart uint64
+	pidns       uint64
+	exe         string
+}
+
+type grant struct {
+	expiry time.Time
+	sticky bool
+}
+
+// Grants is a confirmation cache scoped to (uid, session, sandbox, binary).
+//
+// A grant is either time-bounded (expiry) or sticky. Because the key embeds the
+// session id and the session leader's start time, a sticky grant only ever
+// benefits the exact live session it was issued for: once that session ends, no
+// future process can match the key (a reused sid number gets a different leader
+// start time). The key also embeds the peer's pid namespace, so two sandboxes
+// launched from the same terminal never share a grant. Grants are in-memory and
+// vanish when the agent recycles.
+//
+// The per-exe dimension is the novel-binary gate: approving `ssh` in a session
+// does not silently authorise a different binary that connects from the same
+// session.
+type Grants struct {
+	mu  sync.Mutex
+	m   map[grantKey]grant
+	now func() time.Time
+}
+
+func NewGrants() *Grants {
+	return &Grants{m: map[grantKey]grant{}, now: time.Now}
+}
+
+func keyOf(id Identity) grantKey {
+	return grantKey{uid: id.UID, sid: id.SID, leaderStart: id.LeaderStart, pidns: id.PidNS, exe: id.Exe}
+}
+
+// Allowed reports whether a live grant covers id. Unidentified peers
+// (OK==false) are never allowed.
+func (g *Grants) Allowed(id Identity) bool {
+	if !id.OK {
+		return false
+	}
+	g.mu.Lock()
+	defer g.mu.Unlock()
+	k := keyOf(id)
+	gr, ok := g.m[k]
+	if !ok {
+		return false
+	}
+	if gr.sticky {
+		return true
+	}
+	if g.now().Before(gr.expiry) {
+		return true
+	}
+	delete(g.m, k)
+	return false
+}
+
+// Grant records approval for id. A sticky grant ignores ttl.
+func (g *Grants) Grant(id Identity, sticky bool, ttl time.Duration) {
+	if !id.OK {
+		return
+	}
+	g.mu.Lock()
+	defer g.mu.Unlock()
+	g.m[keyOf(id)] = grant{expiry: g.now().Add(ttl), sticky: sticky}
+}
diff --git a/internal/peerid/peerid.go b/internal/peerid/peerid.go
new file mode 100644
index 0000000..398296a
--- /dev/null
+++ b/internal/peerid/peerid.go
@@ -0,0 +1,230 @@
+// Package peerid resolves the identity of the process connected to the agent
+// socket and caches confirmation grants scoped to (user, session, sandbox,
+// binary).
+//
+// Identity facts are taken only from kernel-authoritative sources: SO_PEERCRED
+// (uid/pid, stamped at connect) and /proc entries the peer cannot forge about
+// itself (session id, session-leader start time, pid namespace, the real exe
+// path). The human-readable ancestry chain and the comm names within it are
+// display-only.
+package peerid
+
+import (
+	"bytes"
+	"fmt"
+	"net"
+	"os"
+	"strconv"
+	"strings"
+
+	"golang.org/x/sys/unix"
+)
+
+const (
+	maxPeerChain   = 4
+	maxSessionHops = 8
+)
+
+// Identity describes the process at the other end of an agent connection.
+type Identity struct {
+	UID         uint32 // peer real uid (SO_PEERCRED)
+	PID         int    // connecting process
+	SID         int    // enclosing login/terminal session (see resolveSession)
+	LeaderStart uint64 // session-leader start time; pins SID against reuse
+	PidNS       uint64 // peer pid-namespace inode; separates sandboxes
+	Exe         string // resolved path of the connecting binary
+	Headless    bool   // no graphical display reachable for the peer
+	Chain       string // human-readable ancestry, for the prompt only
+	OK          bool   // false when the peer could not be identified
+}
+
+// Resolve inspects the peer of c. It never errors: on any failure it returns an
+// Identity with OK=false, which callers MUST treat as "prompt every time, never
+// cache".
+func Resolve(c *net.UnixConn) Identity {
+	var id Identity
+	rc, err := c.SyscallConn()
+	if err != nil {
+		return id
+	}
+	var ucred *unix.Ucred
+	var uerr error
+	if cerr := rc.Control(func(fd uintptr) {
+		ucred, uerr = unix.GetsockoptUcred(int(fd), unix.SOL_SOCKET, unix.SO_PEERCRED)
+	}); cerr != nil || uerr != nil || ucred == nil {
+		return id
+	}
+	id.UID = ucred.Uid
+	id.PID = int(ucred.Pid)
+	if id.PID <= 1 {
+		return id
+	}
+
+	ppid, sid, _, start, ok := readStat(id.PID)
+	if !ok {
+		return id
+	}
+	// A process manager (e.g. omp) may spawn the requester via setsid(), making
+	// it its own session leader with a session id unique to this one invocation;
+	// keying a grant on that re-prompts every time. Resolve the enclosing session
+	// the requester detached from so a grant tracks the launching terminal.
+	id.SID, id.LeaderStart = resolveSession(id.PID, ppid, sid, start, func(p int) (statSnap, bool) {
+		pp, sd, _, st, ok := readStat(p)
+		return statSnap{ppid: pp, sid: sd, start: st}, ok
+	})
+	// The pid namespace separates one sandbox from another: every sbox session
+	// runs in its own, so two sandboxes launched from the same terminal (same
+	// SID) still get distinct grants, while repeat requests from one sandbox
+	// share it. Non-sandboxed peers share the init namespace, leaving them
+	// scoped by SID alone (the original per-terminal behaviour).
+	id.PidNS = readPidNS(id.PID)
+	id.Exe = readExe(id.PID)
+	id.Headless = isHeadless(id.PID)
+	id.Chain = chain(id.PID)
+
+	// Without the exe we cannot run the novel-binary gate, so refuse to cache.
+	id.OK = id.Exe != ""
+	return id
+}
+
+// statSnap is the subset of /proc/<pid>/stat the session walk needs.
+type statSnap struct {
+	ppid  int
+	sid   int
+	start uint64
+}
+
+// resolveSession returns the session a grant should be scoped to and that
+// session leader's start time (which pins the session id against pid reuse).
+//
+// Normally the peer inherited its login/terminal session (sid != pid) and the
+// loop body never runs. But a process manager may setsid() the requester,
+// making it its own session leader (sid == pid) with an id unique to a single
+// invocation. We then follow the parent chain past any such detached leaders to
+// the first enclosing session, so repeat requests from the same terminal/sandbox
+// keep matching one grant.
+func resolveSession(pid, ppid, sid int, peerStart uint64, lookup func(int) (statSnap, bool)) (int, uint64) {
+	for hops := 0; sid == pid && ppid > 1 && hops < maxSessionHops; hops++ {
+		p, ok := lookup(ppid)
+		if !ok {
+			break
+		}
+		pid, sid, ppid = ppid, p.sid, p.ppid
+	}
+	if leader, ok := lookup(sid); ok {
+		return sid, leader.start
+	}
+	return sid, peerStart
+}
+
+func readStat(pid int) (ppid, sid, pgid int, starttime uint64, ok bool) {
+	b, err := os.ReadFile(fmt.Sprintf("/proc/%d/stat", pid))
+	if err != nil {
+		return
+	}
+	return parseStat(b)
+}
+
+// parseStat extracts parent pid, session id, process-group id and start time
+// from the contents of /proc/<pid>/stat. comm (field 2) is wrapped in
+// parentheses and may itself contain spaces and parentheses, so anchor on the
+// final ')'.
+func parseStat(b []byte) (ppid, sid, pgid int, starttime uint64, ok bool) {
+	i := bytes.LastIndexByte(b, ')')
+	if i < 0 || i+1 >= len(b) {
+		return
+	}
+	// fields[0] is field 3 (state); field K maps to fields[K-3].
+	fields := strings.Fields(string(b[i+1:]))
+	if len(fields) < 20 {
+		return
+	}
+	ppid, _ = strconv.Atoi(fields[1])                    // field 4
+	pgid, _ = strconv.Atoi(fields[2])                    // field 5
+	sid, _ = strconv.Atoi(fields[3])                     // field 6
+	starttime, _ = strconv.ParseUint(fields[19], 10, 64) // field 22
+	ok = true
+	return
+}
+
+// readPidNS returns the inode of the peer's pid namespace, or 0 if it cannot be
+// read. /proc/<pid>/ns/pid is a symlink of the form "pid:[4026531836]".
+func readPidNS(pid int) uint64 {
+	l, err := os.Readlink(fmt.Sprintf("/proc/%d/ns/pid", pid))
+	if err != nil {
+		return 0
+	}
+	a := strings.IndexByte(l, '[')
+	b := strings.LastIndexByte(l, ']')
+	if a < 0 || b <= a+1 {
+		return 0
+	}
+	n, _ := strconv.ParseUint(l[a+1:b], 10, 64)
+	return n
+}
+
+func readExe(pid int) string {
+	p, err := os.Readlink(fmt.Sprintf("/proc/%d/exe", pid))
+	if err != nil {
+		return ""
+	}
+	return p
+}
+
+func isHeadless(pid int) bool {
+	b, err := os.ReadFile(fmt.Sprintf("/proc/%d/environ", pid))
+	if err != nil {
+		// Can't tell; assume an interactive GUI (the common local case)
+		// rather than silently routing to the headless PIN path.
+		return false
+	}
+	return headlessFromEnviron(b)
+}
+
+// headlessFromEnviron reports whether a NUL-separated environment block lacks a
+// usable graphical display.
+func headlessFromEnviron(b []byte) bool {
+	for _, kv := range bytes.Split(b, []byte{0}) {
+		eq := bytes.IndexByte(kv, '=')
+		if eq < 0 {
+			continue
+		}
+		k := string(kv[:eq])
+		if (k == "WAYLAND_DISPLAY" || k == "DISPLAY") && eq+1 < len(kv) {
+			return false
+		}
+	}
+	return true
+}
+
+func chain(pid int) string {
+	var parts []string
+	for i := 0; i < maxPeerChain && pid > 1; i++ {
+		name, ppid := procName(pid)
+		if name == "" {
+			break
+		}
+		if i == 0 {
+			name = fmt.Sprintf("%s (%d)", name, pid)
+		}
+		parts = append(parts, name)
+		pid = ppid
+	}
+	return strings.Join(parts, " ← ")
+}
+
+func procName(pid int) (name string, ppid int) {
+	b, err := os.ReadFile(fmt.Sprintf("/proc/%d/status", pid))
+	if err != nil {
+		return
+	}
+	for _, line := range strings.Split(string(b), "\n") {
+		if v, ok := strings.CutPrefix(line, "Name:"); ok {
+			name = strings.TrimSpace(v)
+		} else if v, ok := strings.CutPrefix(line, "PPid:"); ok {
+			ppid, _ = strconv.Atoi(strings.TrimSpace(v))
+			return
+		}
+	}
+	return
+}
