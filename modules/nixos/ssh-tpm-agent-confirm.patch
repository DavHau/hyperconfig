+func TestHeadlessFromEarliest(t *testing.T) {
+	cases := []struct {
+		name string
+		env  []byte
+		want bool
+	}{
+		{"wayland present", []byte("PATH=/bin\x00WAYLAND_DISPLAY=wayland-1\x00"), false},
+		{"x11 present", []byte("DISPLAY=:0\x00HOME=/h\x00"), false},
+		{"no display", []byte("PATH=/bin\x00SSH_CONNECTION=a b c d\x00"), true},
+		{"empty display value is headless", []byte("WAYLAND_DISPLAY=\x00"), true},
+		{"empty environ", []byte{}, true},
+	}
+	for _, c := range cases {
+		t.Run(c.name, func(t *testing.T) {
+			if got := headlessFromEnviron(c.env); got != c.want {
+				t.Errorf("headlessFromEnviron = %v, want %v", got, c.want)
+			}
+		})
+	}
+}
