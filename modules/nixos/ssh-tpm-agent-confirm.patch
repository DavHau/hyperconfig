+++ b/internal/peerid/peerid_test.go
@@ -0,0 +1,219 @@
+package peerid
+
+import (
+	"os"
+	"testing"
+	"time"
+)
+
+// chainOf builds an identity whose ancestry is procs[0] (the peer) up to its
+// outermost ancestor.
+func chainOf(procs ...Proc) Identity {
+	return Identity{Ancestry: procs}
+}
+
+func TestGrantOnAncestorCoversDescendants(t *testing.T) {
+	g := NewGrants()
+	sbox := Proc{PID: 100, Start: 10, Name: "bwrap"}
+
+	// User approves the sandbox root.
+	g.Grant(sbox, false, 15*time.Minute)
+
+	// A later, different ssh under the same sandbox is covered.
+	ssh2 := chainOf(
+		Proc{PID: 205, Start: 55, Name: "ssh"},
+		Proc{PID: 201, Start: 51, Name: "omp"},
+		sbox,
+	)
+	if !g.Allowed(ssh2) {
+		t.Error("descendant of a granted process must be allowed")
+	}
+
+	// A process outside the sandbox is not.
+	other := chainOf(
+		Proc{PID: 300, Start: 60, Name: "ssh"},
+		Proc{PID: 7, Start: 1, Name: "zsh"},
+	)
+	if g.Allowed(other) {
+		t.Error("process outside the granted subtree must re-confirm")
+	}
+}
+
+func TestGrantExpires(t *testing.T) {
+	g := NewGrants()
+	now := time.Unix(1000, 0)
+	g.now = func() time.Time { return now }
+
+	sbox := Proc{PID: 100, Start: 10, Name: "bwrap"}
+	g.Grant(sbox, false, 15*time.Minute)
+	peer := chainOf(Proc{PID: 205, Start: 55, Name: "ssh"}, sbox)
+
+	now = now.Add(14 * time.Minute)
+	if !g.Allowed(peer) {
+		t.Error("grant must still be live before ttl")
+	}
+	now = now.Add(2 * time.Minute) // 16m total > 15m ttl
+	if g.Allowed(peer) {
+		t.Error("grant must expire after ttl")
+	}
+}
+
+func TestStickyGrantNeverExpires(t *testing.T) {
+	g := NewGrants()
+	now := time.Unix(1000, 0)
+	g.now = func() time.Time { return now }
+
+	sbox := Proc{PID: 100, Start: 10, Name: "bwrap"}
+	g.Grant(sbox, true, 15*time.Minute)
+	now = now.Add(100 * time.Hour)
+	if !g.Allowed(chainOf(Proc{PID: 205, Start: 55, Name: "ssh"}, sbox)) {
+		t.Error("sticky grant must survive arbitrary time")
+	}
+}
+
+func TestReusedPidDoesNotInheritGrant(t *testing.T) {
+	g := NewGrants()
+	g.Grant(Proc{PID: 100, Start: 10, Name: "bwrap"}, true, time.Minute)
+
+	// Same pid number, different start time = a new process.
+	reused := chainOf(
+		Proc{PID: 205, Start: 55, Name: "ssh"},
+		Proc{PID: 100, Start: 999, Name: "bwrap"},
+	)
+	if g.Allowed(reused) {
+		t.Error("a reused pid with a different start time must re-confirm")
+	}
+}
+
+func TestUnidentifiedPeerNeverAllowed(t *testing.T) {
+	g := NewGrants()
+	g.Grant(Proc{PID: 100, Start: 10, Name: "bwrap"}, true, time.Minute)
+	if g.Allowed(Identity{}) {
+		t.Error("a peer with no ancestry must never be allowed")
+	}
+}
