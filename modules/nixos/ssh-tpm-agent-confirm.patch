+func id(exe string) Identity {
+	return Identity{UID: 1000, SID: 500, LeaderStart: 12345, Exe: exe, OK: true}
+}
+
+func TestGrantTemporaryExpires(t *testing.T) {
+	g := NewGrants()
+	now := time.Unix(1000, 0)
+	g.now = func() time.Time { return now }
+
+	g.Grant(id("/bin/ssh"), false, 15*time.Minute)
+	if !g.Allowed(id("/bin/ssh")) {
+		t.Fatal("grant should be live immediately")
+	}
+	now = now.Add(14 * time.Minute)
+	if !g.Allowed(id("/bin/ssh")) {
+		t.Error("grant should still be live before ttl")
+	}
+	now = now.Add(2 * time.Minute) // 16m total > 15m ttl
+	if g.Allowed(id("/bin/ssh")) {
+		t.Error("grant should have expired after ttl")
+	}
+}
+
+func TestGrantStickyNeverExpires(t *testing.T) {
+	g := NewGrants()
+	now := time.Unix(1000, 0)
+	g.now = func() time.Time { return now }
+
+	g.Grant(id("/bin/ssh"), true, 15*time.Minute)
+	now = now.Add(100 * time.Hour)
+	if !g.Allowed(id("/bin/ssh")) {
+		t.Error("sticky grant must survive arbitrary time")
+	}
+}
+
+func TestNovelExeGate(t *testing.T) {
+	g := NewGrants()
+	g.Grant(id("/bin/ssh"), true, time.Minute)
+	if g.Allowed(id("/bin/evil")) {
+		t.Error("a different binary in the same session must not inherit the grant")
+	}
+	if !g.Allowed(id("/bin/ssh")) {
+		t.Error("the granted binary should still be allowed")
+	}
+}
+
+func TestDifferentSessionGate(t *testing.T) {
+	g := NewGrants()
+	g.Grant(id("/bin/ssh"), true, time.Minute)
+
+	other := id("/bin/ssh")
+	other.SID = 999 // different terminal/session
+	if g.Allowed(other) {
+		t.Error("a different session must re-confirm")
+	}
+
+	reused := id("/bin/ssh")
+	reused.LeaderStart = 99999 // same sid number, new leader -> reuse-safe
+	if g.Allowed(reused) {
+		t.Error("a reused sid with a different leader start must re-confirm")
+	}
+}
+
+func TestDifferentSandboxGate(t *testing.T) {
+	g := NewGrants()
+	g.Grant(id("/bin/ssh"), true, time.Minute)
+
+	// Same uid/session/binary but a different pid namespace = a different
+	// sandbox launched from the same terminal; it must re-confirm.
+	other := id("/bin/ssh")
+	other.PidNS = 4026533663
+	if g.Allowed(other) {
+		t.Error("a different sandbox (pid namespace) must re-confirm")
+	}
+	// The granting sandbox still matches.
+	if !g.Allowed(id("/bin/ssh")) {
+		t.Error("the granting sandbox should still be allowed")
+	}
+}
+
+func TestUnidentifiedNeverCached(t *testing.T) {
+	g := NewGrants()
+	un := id("/bin/ssh")
+	un.OK = false
+	g.Grant(un, true, time.Minute) // must be a no-op
+	if g.Allowed(un) {
+		t.Error("unidentified peers must never be allowed from cache")
+	}
+	// Even if a matching OK identity exists, the no-op grant means no entry.
+	if g.Allowed(id("/bin/ssh")) {
+		t.Error("grant on unidentified peer must not create a cache entry")
+	}
+}
