+func TestParseStat(t *testing.T) {
+	// comm contains spaces and parentheses; fields after the final ')' are:
+	// state ppid pgrp session tty ... (field 22 = starttime).
+	// Build: pid (comm) then fields 3..22.
+	rest := "S 1000 4242 7777 34816 4242 0 0 0 0 0 0 0 0 20 0 1 0 0 99887766"
+	line := []byte("1234 (we (ird) proc) " + rest + "\n")
+	ppid, sid, pgid, start, ok := parseStat(line)
+	if !ok {
+		t.Fatal("parseStat returned ok=false")
+	}
+	if ppid != 1000 {
+		t.Errorf("ppid = %d, want 1000", ppid)
+	}
+	if sid != 7777 {
+		t.Errorf("sid = %d, want 7777", sid)
+	}
+	if pgid != 4242 {
+		t.Errorf("pgid = %d, want 4242", pgid)
+	}
+	if start != 99887766 {
+		t.Errorf("starttime = %d, want 99887766", start)
+	}
+}
+
+func TestParseStatTooShort(t *testing.T) {
+	if _, _, _, _, ok := parseStat([]byte("1 (init) S 0 1 1")); ok {
+		t.Error("expected ok=false for a truncated stat line")
+	}
+	if _, _, _, _, ok := parseStat([]byte("garbage without paren")); ok {
+		t.Error("expected ok=false when there is no comm close paren")
+	}
+}
