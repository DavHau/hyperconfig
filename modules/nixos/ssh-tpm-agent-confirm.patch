+func snapLookup(m map[int]statSnap) func(int) (statSnap, bool) {
+	return func(p int) (statSnap, bool) { s, ok := m[p]; return s, ok }
+}
+
+func TestResolveSessionNormalPeer(t *testing.T) {
+	// A peer launched from a shell inherits the shell's session (sid != pid);
+	// the session resolves directly with no parent walk.
+	lookup := snapLookup(map[int]statSnap{
+		100: {ppid: 7, sid: 7, start: 999},
+		7:   {ppid: 1, sid: 7, start: 100},
+	})
+	sid, ls := resolveSession(100, 7, 7, 999, lookup)
+	if sid != 7 || ls != 100 {
+		t.Errorf("got sid=%d leaderStart=%d, want 7,100", sid, ls)
+	}
+}
+
+func TestResolveSessionSkipsDetachedLeader(t *testing.T) {
+	// omp setsid()s ssh, so ssh is its own session leader (sid == pid). The
+	// session must resolve to the enclosing login session (7) of its parent,
+	// not to the per-invocation ssh session.
+	lookup := snapLookup(map[int]statSnap{
+		100: {ppid: 50, sid: 100, start: 999}, // ssh, detached
+		50:  {ppid: 40, sid: 7, start: 500},   // omp, member of session 7
+		7:   {ppid: 1, sid: 7, start: 100},    // login shell, session leader
+	})
+	sid, ls := resolveSession(100, 50, 100, 999, lookup)
+	if sid != 7 {
+		t.Errorf("sid = %d, want 7 (enclosing session, not detached ssh)", sid)
+	}
+	if ls != 100 {
+		t.Errorf("leaderStart = %d, want 100 (session-7 leader start)", ls)
+	}
+}
+
+func TestResolveSessionNestedDetached(t *testing.T) {
+	// ssh <- git <- omp, where omp setsid()s both git and ssh. The walk must
+	// skip both detached leaders and land on omp's session.
+	lookup := snapLookup(map[int]statSnap{
+		200: {ppid: 150, sid: 200, start: 30}, // ssh, detached
+		150: {ppid: 50, sid: 150, start: 20},  // git, detached
+		50:  {ppid: 1, sid: 7, start: 10},     // omp, session 7
+		7:   {ppid: 1, sid: 7, start: 5},
+	})
+	sid, ls := resolveSession(200, 150, 200, 30, lookup)
+	if sid != 7 || ls != 5 {
+		t.Errorf("got sid=%d leaderStart=%d, want 7,5", sid, ls)
+	}
+}
+
+func TestResolveSessionLeaderUnreadableFallsBack(t *testing.T) {
+	// Nothing readable up the chain: keep the peer's own session and start time
+	// rather than inventing one (still a valid, if per-invocation, scope).
+	sid, ls := resolveSession(100, 1, 100, 999, snapLookup(map[int]statSnap{}))
+	if sid != 100 || ls != 999 {
+		t.Errorf("got sid=%d leaderStart=%d, want 100,999 (peer-start fallback)", sid, ls)
+	}
+}
