diff --git a/internal/peerid/grant.go b/internal/peerid/grant.go
new file mode 100644
index 0000000..280964b
--- /dev/null
+++ b/internal/peerid/grant.go
@@ -0,0 +1,65 @@
+package peerid
+
+import (
+	"sync"
+	"time"
+)
+
+type procKey struct {
+	pid   int
+	start uint64
+}
+
+type grant struct {
+	expiry time.Time
+	sticky bool
+}
+
+// Grants caches user confirmations. Each grant names one process (by pid +
+// start time) and covers that process and all of its descendants: a peer is
+// allowed when ANY process in its ancestry holds a live grant.
+//
+// A grant is either time-bounded (expiry) or sticky. A sticky grant lives
+// until the agent recycles or the granted process dies — once its pid is
+// reused, the start time no longer matches and nothing can hit the entry
+// again. Grants are in-memory only.
+type Grants struct {
+	mu  sync.Mutex
+	m   map[procKey]grant
+	now func() time.Time
+}
+
+func NewGrants() *Grants {
+	return &Grants{m: map[procKey]grant{}, now: time.Now}
+}
+
+// Allowed reports whether a live grant covers id, i.e. whether any process in
+// its ancestry has been granted. Unidentified peers (empty ancestry) are never
+// allowed.
+func (g *Grants) Allowed(id Identity) bool {
+	g.mu.Lock()
+	defer g.mu.Unlock()
+	for _, p := range id.Ancestry {
+		k := procKey{pid: p.PID, start: p.Start}
+		gr, ok := g.m[k]
+		if !ok {
+			continue
+		}
+		if gr.sticky || g.now().Before(gr.expiry) {
+			return true
+		}
+		delete(g.m, k)
+	}
+	return false
+}
+
+// Grant records approval for p and all of its descendants. A sticky grant
+// ignores ttl.
+func (g *Grants) Grant(p Proc, sticky bool, ttl time.Duration) {
+	if p.PID <= 1 {
+		return
+	}
+	g.mu.Lock()
+	defer g.mu.Unlock()
+	g.m[procKey{pid: p.PID, start: p.Start}] = grant{expiry: g.now().Add(ttl), sticky: sticky}
+}
diff --git a/internal/peerid/peerid.go b/internal/peerid/peerid.go
new file mode 100644
index 0000000..7ff5b6a
--- /dev/null
+++ b/internal/peerid/peerid.go
@@ -0,0 +1,183 @@
+// Package peerid identifies the process connected to the agent socket by its
+// process ancestry and caches user-issued confirmation grants.
+//
+// The model is deliberately simple: the user grants trust to ONE process out
+// of the peer's ancestry chain (e.g. the sandbox root, the process manager, or
+// the ssh binary itself), and that grant covers the process and every
+// descendant of it. A grant is keyed by (pid, starttime), so a recycled pid
+// never inherits it. Everything is read from /proc/<pid>/stat, which is
+// world-readable even for processes inside foreign user/pid namespaces
+// (sandboxes) — unlike /proc/<pid>/exe or /proc/<pid>/ns/*, which need ptrace
+// permission and made earlier, finer-grained scoping schemes fail there.
+package peerid
+
+import (
+	"bytes"
+	"fmt"
+	"net"
+	"os"
+	"strconv"
+	"strings"
+
+	"golang.org/x/sys/unix"
+)
+
+const (
+	// maxDisplayChain bounds the ancestry shown in the prompt and offered as
+	// grant targets.
+	maxDisplayChain = 4
+	// maxAncestry bounds the /proc walk when matching grants; deep enough for
+	// any real process tree.
+	maxAncestry = 32
+)
+
+// Proc is one process in the peer's ancestry.
+type Proc struct {
+	PID   int
+	Start uint64 // starttime from /proc/<pid>/stat; pins the PID against reuse
+	Name  string // comm, display only
+}
+
+// Identity describes the process at the other end of an agent connection.
+type Identity struct {
+	// Ancestry lists the connecting process first, then its parents up to
+	// (not including) pid 1, bounded by maxAncestry. Empty when the peer
+	// could not be identified; such peers are prompted every time and never
+	// cached.
+	Ancestry []Proc
+	Headless bool // no graphical display reachable for the peer
+}
+
+// Chain returns the human-readable ancestry for the prompt, e.g.
+// "ssh (1234) ← omp ← bwrap".
+func (id Identity) Chain() string {
+	var parts []string
+	for i, p := range id.Choices() {
+		if i == 0 {
+			parts = append(parts, fmt.Sprintf("%s (%d)", p.Name, p.PID))
+		} else {
+			parts = append(parts, p.Name)
+		}
+	}
+	return strings.Join(parts, " ← ")
+}
+
+// Choices returns the ancestors the user may grant trust to (the displayed
+// prefix of the ancestry).
+func (id Identity) Choices() []Proc {
+	if len(id.Ancestry) > maxDisplayChain {
+		return id.Ancestry[:maxDisplayChain]
+	}
+	return id.Ancestry
+}
+
+// Find returns the ancestor with the given pid.
+func (id Identity) Find(pid int) (Proc, bool) {
+	for _, p := range id.Ancestry {
+		if p.PID == pid {
+			return p, true
+		}
+	}
+	return Proc{}, false
+}
+
+// Resolve inspects the peer of c. It never errors: on any failure it returns
+// an Identity with an empty Ancestry, which callers MUST treat as "prompt
+// every time, never cache".
+func Resolve(c *net.UnixConn) Identity {
+	var id Identity
+	rc, err := c.SyscallConn()
+	if err != nil {
+		return id
+	}
+	var ucred *unix.Ucred
+	var uerr error
+	if cerr := rc.Control(func(fd uintptr) {
+		ucred, uerr = unix.GetsockoptUcred(int(fd), unix.SOL_SOCKET, unix.SO_PEERCRED)
+	}); cerr != nil || uerr != nil || ucred == nil {
+		return id
+	}
+	pid := int(ucred.Pid)
+	if pid <= 1 {
+		return id
+	}
+	id.Ancestry = ancestryOf(pid, readStat)
+	id.Headless = isHeadless(pid)
+	return id
+}
+
+// procStat is the subset of /proc/<pid>/stat the ancestry walk needs.
+type procStat struct {
+	name  string
+	ppid  int
+	start uint64
+}
+
+// ancestryOf walks pid's parent chain via lookup, connecting process first,
+// stopping before pid 1.
+func ancestryOf(pid int, lookup func(int) (procStat, bool)) []Proc {
+	var chain []Proc
+	for len(chain) < maxAncestry && pid > 1 {
+		s, ok := lookup(pid)
+		if !ok {
+			break
+		}
+		chain = append(chain, Proc{PID: pid, Start: s.start, Name: s.name})
+		pid = s.ppid
+	}
+	return chain
+}
+
+func readStat(pid int) (procStat, bool) {
+	b, err := os.ReadFile(fmt.Sprintf("/proc/%d/stat", pid))
+	if err != nil {
+		return procStat{}, false
+	}
+	return parseStat(b)
+}
+
+// parseStat extracts comm, parent pid and start time from the contents of
+// /proc/<pid>/stat. comm (field 2) is wrapped in parentheses and may itself
+// contain spaces and parentheses, so anchor on the final ')'.
+func parseStat(b []byte) (procStat, bool) {
+	open := bytes.IndexByte(b, '(')
+	close := bytes.LastIndexByte(b, ')')
+	if open < 0 || close <= open || close+1 >= len(b) {
+		return procStat{}, false
+	}
+	// fields[0] is field 3 (state); field K maps to fields[K-3].
+	fields := strings.Fields(string(b[close+1:]))
+	if len(fields) < 20 {
+		return procStat{}, false
+	}
+	ppid, _ := strconv.Atoi(fields[1])                     // field 4
+	start, _ := strconv.ParseUint(fields[19], 10, 64)      // field 22
+	return procStat{name: string(b[open+1 : close]), ppid: ppid, start: start}, true
+}
+
+func isHeadless(pid int) bool {
+	b, err := os.ReadFile(fmt.Sprintf("/proc/%d/environ", pid))
+	if err != nil {
+		// Can't tell (e.g. a sandboxed peer); assume an interactive GUI (the
+		// common local case) rather than silently routing to the headless PIN
+		// path.
+		return false
+	}
+	return headlessFromEnviron(b)
+}
+
+// headlessFromEnviron reports whether a NUL-separated environment block lacks
+// a usable graphical display.
+func headlessFromEnviron(b []byte) bool {
+	for _, kv := range bytes.Split(b, []byte{0}) {
+		eq := bytes.IndexByte(kv, '=')
+		if eq < 0 {
+			continue
+		}
+		k := string(kv[:eq])
+		if (k == "WAYLAND_DISPLAY" || k == "DISPLAY") && eq+1 < len(kv) {
+			return false
+		}
+	}
+	return true
+}
