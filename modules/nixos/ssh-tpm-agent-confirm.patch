+func TestParseStat(t *testing.T) {
+	// comm contains spaces and parentheses; fields after the final ')' are:
+	// state ppid pgrp session tty ... (field 22 = starttime).
+	rest := "S 1000 4242 7777 34816 4242 0 0 0 0 0 0 0 0 20 0 1 0 0 99887766"
+	s, ok := parseStat([]byte("1234 (we (ird) proc) " + rest + "\n"))
+	if !ok {
+		t.Fatal("parseStat returned ok=false")
+	}
+	if s.name != "we (ird) proc" {
+		t.Errorf("name = %q, want %q", s.name, "we (ird) proc")
+	}
+	if s.ppid != 1000 {
+		t.Errorf("ppid = %d, want 1000", s.ppid)
+	}
+	if s.start != 99887766 {
+		t.Errorf("start = %d, want 99887766", s.start)
+	}
+}
+
+func TestParseStatMalformed(t *testing.T) {
+	if _, ok := parseStat([]byte("1 (init) S 0 1 1")); ok {
+		t.Error("expected ok=false for a truncated stat line")
+	}
+	if _, ok := parseStat([]byte("garbage without paren")); ok {
+		t.Error("expected ok=false when there is no comm close paren")
+	}
+}
