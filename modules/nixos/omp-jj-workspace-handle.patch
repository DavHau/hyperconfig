+		await fs.writeFile(path.join(repo, "live.txt"), "live\n");
+
+		const handle = await jjHandle(repo);
+		const baseline = await handle.captureBaseline();
+
+		expect(baseline.root.headCommit).toMatch(/^[0-9a-f]{40}$/);
+		expect(baseline.nested).toEqual([]);
+		// The baseline commit must contain the live edit (jj auto-tracks).
