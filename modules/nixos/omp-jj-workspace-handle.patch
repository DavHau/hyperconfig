diff --git a/packages/coding-agent/src/task/vcs-jj.ts b/packages/coding-agent/src/task/vcs-jj.ts
new file mode 100644
index 000000000..d839f86ac
--- /dev/null
+++ b/packages/coding-agent/src/task/vcs-jj.ts
@@ -0,0 +1,347 @@
+/**
+ * jj-workspace implementation of the {@link VcsHandle} seam.
+ *
+ * jj's default backend is git: every jj commit is a real git commit in a
+ * store discoverable from any workspace (`.jj/repo` — a directory in the
+ * default workspace, a pointer FILE in `jj workspace add` secondaries —
+ * `store/git_target` → git dir). This handle runs the capture phase with git
+ * *plumbing* against that backing store (explicit `--git-dir`/`--work-tree`,
+ * throwaway index, temp object dir for read-only probes) and lands changes
+ * through jj itself, so:
+ *
+ *   - no `.git/` checkout is required in the workspace,
+ *   - the shared store is never mutated except by append-only object writes
+ *     and `refs/omp/task/*` updates (invisible to jj's ref import),
+ *   - the parent workspace is only ever touched by an atomic `git apply` of
+ *     a pre-validated merge, inside a fresh `jj new` landing commit — on any
+ *     conflict nothing is written at all (jj's op log covers the rest).
+ *
+ * Capture:    baseline = `@` commit id (jj auto-snapshots on read).
+ * Merge-back: `git merge-tree --write-tree` (3-way, in-store, no worktree)
+ *             → clean: materialize via `git apply`, snapshot with `jj st`;
+ *             → conflict: report failed, keep the task ref parked, touch
+ *               nothing.
+ *
+ * Nested git repositories under a jj workspace are out of scope: baselines
+ * report none and nested patch application is a no-op.
+ */
+import * as fs from "node:fs/promises";
+import * as os from "node:os";
+import * as path from "node:path";
+import * as jj from "../utils/jj";
+import type { TaskRefMergeSpec, VcsHandle } from "./vcs";
+import {
+	type CommitToBranchResult,
+	type DeltaPatchResult,
+	type MergeBranchResult,
+	type NestedRepoPatch,
+	taskBranchRef,
+	type WorktreeBaseline,
+} from "./worktree";
+
+interface GitRunOptions {
+	/** Extra environment (index/object-dir redirection). */
+	env?: Record<string, string>;
+	/** Working directory for pathspec-relative commands (`add`). */
+	cwd?: string;
+	/** Return the result instead of throwing on non-zero exit. */
+	allowFailure?: boolean;
+}
+
+interface GitRunResult {
+	exitCode: number;
+	stdout: string;
+	stderr: string;
+}
+
+async function runGit(gitDir: string, args: string[], options: GitRunOptions = {}): Promise<GitRunResult> {
+	const child = Bun.spawn(["git", "--git-dir", gitDir, ...args], {
+		cwd: options.cwd,
+		env: { ...process.env, ...options.env },
+		stdin: "ignore",
+		stdout: "pipe",
+		stderr: "pipe",
+		windowsHide: true,
+	});
+	const [stdout, stderr, exitCode] = await Promise.all([
+		new Response(child.stdout).text(),
+		new Response(child.stderr).text(),
+		child.exited,
+	]);
+	const result = { exitCode: exitCode ?? 0, stdout, stderr };
+	if (result.exitCode !== 0 && !options.allowFailure) {
+		throw new Error(`git ${args.join(" ")} failed (exit ${result.exitCode}): ${stderr.trim() || stdout.trim()}`);
+	}
+	return result;
+}
+
+/** `@` commit id of the workspace; any jj read snapshots the working copy first. */
+async function workingCopyCommitId(root: string): Promise<string> {
+	return (await jj.exec(root, ["log", "-r", "@", "--no-graph", "-T", "commit_id"])).trim();
+}
+
+/**
+ * Build a temporary git index describing the full content of `dir` (gitignore
+ * respected, `.jj` excluded) based on the baseline commit, and hand it to
+ * `body`. `objectDir` redirects new blob/tree writes away from the shared
+ * store for read-only probes; when omitted, objects land in the store
+ * (append-only, required for commits that must outlive the temp dir).
+ */
+async function withTreeIndex<T>(
+	gitDir: string,
+	workTree: string,
+	baselineCommit: string,
+	persistObjects: boolean,
+	body: (env: Record<string, string>) => Promise<T>,
+): Promise<T> {
+	const tmp = await fs.mkdtemp(path.join(os.tmpdir(), "omp-jj-vcs-"));
+	try {
+		const env: Record<string, string> = {
+			GIT_INDEX_FILE: path.join(tmp, "index"),
+			GIT_WORK_TREE: workTree,
+		};
+		if (!persistObjects) {
+			const objectDir = path.join(tmp, "objects");
+			await fs.mkdir(objectDir, { recursive: true });
+			env.GIT_OBJECT_DIRECTORY = objectDir;
+			env.GIT_ALTERNATE_OBJECT_DIRECTORIES = path.join(gitDir, "objects");
+		}
+		await runGit(gitDir, ["read-tree", baselineCommit], { env });
+		await runGit(gitDir, ["add", "-A", "--", ".", ":(exclude).jj"], { env, cwd: workTree });
+		return await body(env);
+	} finally {
+		await fs.rm(tmp, { recursive: true, force: true });
+	}
+}
+
+/** jj-side commit identity for synthetic task commits; falls back to a fixed ident. */
+async function commitIdentEnv(root: string): Promise<Record<string, string>> {
+	const name = await jj.exec(root, ["config", "get", "user.name"]).then(
+		out => out.trim() || "OMP Task",
+		() => "OMP Task",
+	);
+	const email = await jj.exec(root, ["config", "get", "user.email"]).then(
+		out => out.trim() || "omp-task@localhost",
+		() => "omp-task@localhost",
+	);
+	return {
+		GIT_AUTHOR_NAME: name,
+		GIT_AUTHOR_EMAIL: email,
+		GIT_COMMITTER_NAME: name,
+		GIT_COMMITTER_EMAIL: email,
+	};
+}
+
+export class JjWorkspaceHandle implements VcsHandle {
+	readonly kind = "jj" as const;
+	constructor(
+		readonly root: string,
+		/** Backing git store directory (resolved through `.jj/repo` → `store/git_target`). */
+		readonly gitDir: string,
+	) {}
+
+	async captureBaseline(): Promise<WorktreeBaseline> {
+		// jj has no staged/unstaged/untracked triad: reading `@` forces a
+		// working-copy snapshot, so the baseline collapses to one commit id.
+		const headCommit = await workingCopyCommitId(this.root);
+		return {
+			root: { repoRoot: this.root, headCommit, staged: "", unstaged: "", untracked: [], untrackedPatch: "" },
+			nested: [],
+		};
+	}
+
+	async captureDelta(isolationDir: string, baseline: WorktreeBaseline): Promise<DeltaPatchResult> {
+		const base = baseline.root.headCommit;
+		const rootPatch = await withTreeIndex(this.gitDir, isolationDir, base, false, async env => {
+			const diff = await runGit(this.gitDir, ["diff", "--cached", "--binary", "--full-index", base], { env });
+			return diff.stdout;
+		});
+		return { rootPatch, nestedPatches: [] };
+	}
+
+	async commitToTaskRef(
+		isolationDir: string,
+		baseline: WorktreeBaseline,
+		taskId: string,
+		description: string | undefined,
+		commitMessage?: (diff: string) => Promise<string | null>,
+	): Promise<CommitToBranchResult | null> {
+		const base = baseline.root.headCommit;
+		return withTreeIndex(this.gitDir, isolationDir, base, true, async env => {
+			const tree = (await runGit(this.gitDir, ["write-tree"], { env })).stdout.trim();
+			const baseTree = (await runGit(this.gitDir, ["rev-parse", `${base}^{tree}`], { env })).stdout.trim();
+			if (tree === baseTree) return null;
+
+			let message: string | null = null;
+			if (commitMessage) {
+				const diff = await runGit(this.gitDir, ["diff", "--cached", base], { env });
+				message = await commitMessage(diff.stdout);
+			}
+			const fallback = description?.trim() ? `omp task ${taskId}: ${description.trim()}` : `omp task ${taskId}`;
+			const ident = await commitIdentEnv(this.root);
+			const commit = (
+				await runGit(this.gitDir, ["commit-tree", tree, "-p", base, "-m", message?.trim() || fallback], {
+					env: { ...env, ...ident },
+				})
+			).stdout.trim();
+
+			const branchName = `omp/task/${taskId}`;
+			await runGit(this.gitDir, ["update-ref", taskBranchRef(branchName), commit]);
+			return { branchName, baseSha: base, nestedPatches: [] };
+		});
+	}
+
+	async mergeTaskRefs(refs: TaskRefMergeSpec[]): Promise<MergeBranchResult> {
+		const merged: string[] = [];
+		const failed: string[] = [];
+		let conflict: string | undefined;
+
+		for (const [index, ref] of refs.entries()) {
+			const fail = (message: string) => {
+				failed.push(ref.branchName, ...refs.slice(index + 1).map(r => r.branchName));
+				conflict = message;
+			};
+
+			const taskSha = (await runGit(this.gitDir, ["rev-parse", "--verify", `${taskBranchRef(ref.branchName)}^{commit}`], { allowFailure: true })).stdout.trim();
+			if (!taskSha) {
+				fail(`Task ref ${ref.branchName} not found in the backing store.`);
+				break;
+			}
+
+			// Snapshot the parent's live edits, then 3-way merge entirely inside
+			// the store — the worktree is not touched unless the merge is clean.
+			const parentSha = await workingCopyCommitId(this.root);
+			const baseSha = ref.baseSha ?? (await runGit(this.gitDir, ["merge-base", parentSha, taskSha])).stdout.trim();
+			const mergeResult = await runGit(
+				this.gitDir,
+				["merge-tree", "--write-tree", `--merge-base=${baseSha}`, parentSha, taskSha],
+				{ allowFailure: true },
+			);
+			if (mergeResult.exitCode !== 0) {
+				const detail = mergeResult.stdout.trim() || mergeResult.stderr.trim();
+				fail(`3-way merge of ${ref.branchName} conflicts with the current workspace state:\n${detail}`);
+				break;
+			}
+			const mergedTree = mergeResult.stdout.trim().split("\n")[0]?.trim() ?? "";
+
+			const patch = (
+				await runGit(this.gitDir, ["diff", "--binary", "--full-index", `${parentSha}^{tree}`, mergedTree])
+			).stdout;
+			if (!patch.trim()) {
+				// Net effect already present (mirrors git mode's empty cherry-pick skip).
+				merged.push(ref.branchName);
+				continue;
+			}
+
+			const message = ref.description?.trim() || `omp task ${ref.taskId}`;
+			await jj.exec(this.root, ["new", "-m", message]);
+			const patchFile = path.join(os.tmpdir(), `omp-jj-land-${Date.now()}-${index}.patch`);
+			await fs.writeFile(patchFile, patch);
+			try {
+				const apply = await runGit(this.gitDir, ["apply", "--binary", patchFile], {
+					env: { GIT_WORK_TREE: this.root },
+					cwd: this.root,
+					allowFailure: true,
+				});
+				if (apply.exitCode !== 0) {
+					// git-apply is atomic: nothing was written. Drop the empty
+					// landing commit and park the ref for manual resolution.
+					await jj.exec(this.root, ["abandon", "@"]);
+					fail(
+						`Applying merged tree of ${ref.branchName} failed (workspace changed mid-merge?): ${apply.stderr.trim()}`,
+					);
+					break;
+				}
+			} finally {
+				await fs.rm(patchFile, { force: true });
+			}
+			// Snapshot the landing commit so the merge is visible in jj history.
+			await jj.exec(this.root, ["status"]);
+			merged.push(ref.branchName);
+		}
+
+		return conflict ? { merged, failed, conflict } : { merged, failed };
+	}
+
+	async cleanupTaskRefs(branchNames: string[]): Promise<void> {
+		for (const branchName of branchNames) {
+			await runGit(this.gitDir, ["update-ref", "-d", taskBranchRef(branchName)], { allowFailure: true });
+		}
+	}
+
+	async canApplyPatch(patchText: string, options?: { reverse?: boolean }): Promise<boolean> {
+		if (!patchText.trim()) return true;
+		const patchFile = path.join(os.tmpdir(), `omp-jj-check-${Date.now()}.patch`);
+		await fs.writeFile(patchFile, patchText.endsWith("\n") ? patchText : `${patchText}\n`);
+		try {
+			const args = ["apply", "--check", "--binary"];
+			if (options?.reverse) args.push("--reverse");
+			args.push(patchFile);
+			const result = await runGit(this.gitDir, args, {
+				env: { GIT_WORK_TREE: this.root },
+				cwd: this.root,
+				allowFailure: true,
+			});
+			return result.exitCode === 0;
+		} finally {
+			await fs.rm(patchFile, { force: true });
+		}
+	}
+
+	async applyPatch(patchText: string): Promise<void> {
+		if (!patchText.trim()) return;
+		const patchFile = path.join(os.tmpdir(), `omp-jj-apply-${Date.now()}.patch`);
+		await fs.writeFile(patchFile, patchText.endsWith("\n") ? patchText : `${patchText}\n`);
+		try {
+			await runGit(this.gitDir, ["apply", "--binary", patchFile], {
+				env: { GIT_WORK_TREE: this.root },
+				cwd: this.root,
+			});
+		} finally {
+			await fs.rm(patchFile, { force: true });
+		}
+		// Fold the applied patch into jj's working-copy commit.
+		await jj.exec(this.root, ["status"]);
+	}
+
+	async applyNestedPatches(
+		patches: NestedRepoPatch[],
+		_commitMessage?: (diff: string) => Promise<string | null>,
+	): Promise<string[]> {
+		// Baselines never report nested repos for jj workspaces, so nothing is
+		// ever captured; keep the contract total anyway.
+		return patches.length === 0 ? [] : ["Nested repository patches are not supported in jj workspaces."];
+	}
+
+	async prepareIsolationDir(isolationDir: string): Promise<void> {
+		// The snapshot clones the workspace *identity*: `.jj/repo` points at the
+		// REAL shared store, so any jj invocation inside the snapshot would race
+		// the parent workspace and write through the isolation boundary. Delete
+		// it (copy-on-write: upper layer only) — capture needs only the files.
+		await fs.rm(path.join(isolationDir, ".jj"), { recursive: true, force: true });
+	}
+}
+
+/**
+ * Resolve the backing git store of the jj workspace containing `cwd`.
+ * Throws when the workspace uses a non-git jj backend.
+ */
+export async function resolveJjWorkspaceHandle(cwd: string): Promise<JjWorkspaceHandle> {
+	const repo = await jj.repo.resolve(cwd);
+	if (!repo) throw new Error("Jujutsu workspace not found for isolated task execution.");
+
+	let gitDir: string | null = null;
+	const targetFile = path.join(repo.storeDir, "git_target");
+	try {
+		gitDir = path.resolve(repo.storeDir, (await fs.readFile(targetFile, "utf8")).trim());
+	} catch {
+		const fallback = path.join(repo.storeDir, "git");
+		gitDir = (await fs.stat(fallback).catch(() => null))?.isDirectory() ? fallback : null;
+	}
+	if (!gitDir || !(await fs.stat(gitDir).catch(() => null))?.isDirectory()) {
+		throw new Error(
+			"Isolated task execution requires a git-backed Jujutsu workspace; this workspace's store has no git backend.",
+		);
+	}
+	return new JjWorkspaceHandle(repo.repoRoot, gitDir);
+}
