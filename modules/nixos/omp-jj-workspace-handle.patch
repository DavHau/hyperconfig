+		expect(await Bun.file(path.join(repo, "task.txt")).text()).toBe("task work\n");
+		// ...parent edit survived...
+		expect(await Bun.file(path.join(repo, "parent.txt")).text()).toBe("parent kept working\n");
+		// ...and the landing commit is visible jj history with the description.
+		const log = await run(repo, ["jj", "log", "--no-graph", "-T", "description ++ \"\\n\""]);
+		expect(log).toContain("add task file");
+
+		await handle.cleanupTaskRefs([branchName]);
+		const refs = await run(repo, ["jj", "log", "--no-graph", "-T", "commit_id"]).then(() => "ok");
+		expect(refs).toBe("ok"); // repo still healthy after ref deletion
+	});
+
+	it("reports conflicts without touching the workspace and keeps the ref parked", async () => {
+		const repo = await createJjRepo();
+		const handle = await jjHandle(repo);
+		const baseline = await handle.captureBaseline();
+		const iso = await snapshotWorkspace(repo);
+		await handle.prepareIsolationDir?.(iso);
+		await fs.writeFile(path.join(iso, "base.txt"), "task version\n");
+		const commit = await handle.commitToTaskRef(iso, baseline, "ConflictTask", "conflicting edit");
+		const branchName = commit?.branchName ?? "";
+
+		// Parent edits the SAME file divergently after the baseline.
+		await fs.writeFile(path.join(repo, "base.txt"), "parent version\n");
+
+		const result = await handle.mergeTaskRefs([
+			{ branchName, taskId: "ConflictTask", description: "conflicting edit", baseSha: commit?.baseSha },
+		]);
+
+		expect(result.merged).toEqual([]);
+		expect(result.failed).toEqual([branchName]);
+		expect(result.conflict).toBeTruthy();
+		// Workspace untouched: parent content intact, no conflict markers.
+		expect(await Bun.file(path.join(repo, "base.txt")).text()).toBe("parent version\n");
+		// Ref still parked for manual resolution.
+		const iso2 = await snapshotWorkspace(repo);
+		await handle.prepareIsolationDir?.(iso2);
+		expect(await handle.commitToTaskRef(iso2, await handle.captureBaseline(), "Probe", undefined)).toBeNull();
+	});
+
+	it("strips the snapshot's .jj pointer in prepareIsolationDir", async () => {
+		const repo = await createJjRepo();
+		const handle = await jjHandle(repo);
+		const iso = await snapshotWorkspace(repo);
+		expect((await fs.stat(path.join(iso, ".jj"))).isDirectory()).toBe(true);
+
+		await handle.prepareIsolationDir?.(iso);
+
+		expect(await fs.stat(path.join(iso, ".jj")).catch(() => null)).toBeNull();
+	});
+});
