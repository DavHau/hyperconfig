+		const handle = await jjHandle(repo);
+		const baseline = await handle.captureBaseline();
+		const iso = await snapshotWorkspace(repo);
+		await handle.prepareIsolationDir?.(iso);
+		await fs.writeFile(path.join(iso, "task.txt"), "task work\n");
+		const commit = await handle.commitToTaskRef(iso, baseline, "LandTask", "add task file");
+		expect(commit?.branchName).toBeDefined();
