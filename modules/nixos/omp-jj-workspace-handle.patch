+describe.skipIf(!jjAvailable)("JjWorkspaceHandle", () => {
+	const tempDirs: string[] = [];
+
+	afterEach(async () => {
+		await Promise.all(tempDirs.splice(0).map(dir => removeWithRetries(dir)));
+	});
+
+	/** Non-colocated jj repo with one tracked file committed under a described change. */
+	async function createJjRepo(): Promise<string> {
+		const repo = await fs.mkdtemp(path.join(os.tmpdir(), "omp-vcs-jjrepo-"));
+		tempDirs.push(repo);
+		await run(repo, ["jj", "git", "init", "--no-colocate"]);
+		await fs.writeFile(path.join(repo, "base.txt"), "base\n");
+		await run(repo, ["jj", "commit", "-m", "base"]);
+		return repo;
+	}
+
+	/** Simulate a PAL snapshot: plain copy of the workspace (rcopy backend shape). */
+	async function snapshotWorkspace(repo: string): Promise<string> {
+		const iso = await fs.mkdtemp(path.join(os.tmpdir(), "omp-vcs-iso-"));
+		tempDirs.push(iso);
+		await fs.cp(repo, iso, { recursive: true });
+		return iso;
+	}
+
+	async function jjHandle(repo: string) {
+		const handle = await resolveVcsHandle(repo);
+		expect(handle.kind).toBe("jj");
